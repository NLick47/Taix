
root = true



[*]
charset = utf-8                   
end_of_line = lf            
trim_trailing_whitespace = true
insert_final_newline = true      


[*.cs]
indent_style = space
indent_size = 4                   
tab_width = 4

csharp_using_directive_placement = outside_namespace


[*.{xaml,axaml}]
indent_style = space
indent_size = 2                   


[*.{csproj,json,yml,yaml,props,targets}]
indent_style = space
indent_size = 2


# [*.sln] end_of_line = crlf