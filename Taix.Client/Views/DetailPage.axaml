<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800"
             d:DesignHeight="450"
             xmlns:base="using:Taix.Client.Controls.Base"
             xmlns:btn="using:Taix.Client.Controls.Button"
             Foreground="{DynamicResource StandardTextBrush}"
             Background="Transparent"
             xmlns:s="using:Taix.Client.Controls.Select"
             xmlns:vm="using:Taix.Client.ViewModels"
             xmlns:Charts="using:Taix.Client.Controls.Charts"
             xmlns:DatePickerBar="using:Taix.Client.Controls.DatePickerBar"
             x:DataType="vm:DetailPageViewModel"
             x:Class="Taix.Client.Views.DetailPage">

    <UserControl.ContextMenu>
        <ContextMenu>
            <MenuItem Header="{DynamicResource Refresh}" />
        </ContextMenu>
    </UserControl.ContextMenu>

    <StackPanel Margin="20">

        <Grid ColumnDefinitions="Auto,*" Margin="0,5,0,20">
            <TextBlock Grid.Column="0" Text="{DynamicResource App}"
                       FontSize="18" VerticalAlignment="Center" />
        </Grid>

        <!--应用基本信息卡片-->
        <Border
            Background="{DynamicResource SettingPanelBgBrush}"
            ContextMenu="{Binding AppContextMenu}"
            CornerRadius="{StaticResource RadiusMedium}"
            Padding="20">

            <Border.Effect>
                <DropShadowEffect BlurRadius="12" Color="#000000" Opacity="0.08" OffsetX="0" OffsetY="3" />
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 图标容器 -->
                <Border Width="48" Height="48" CornerRadius="14" Margin="0,0,15,0"
                        Background="{DynamicResource ControlBackgroundBrush}">
                    <base:Img URL="{Binding App.IconFile}" Width="28" Height="28"
                              DecodeWidth="64"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">
                    <base:View Condition="=False"
                               Value="{Binding IsRegexIgnore}">
                        <Border Background="#f51837" Padding="10,5" CornerRadius="{StaticResource RadiusSmall}" Margin="0,0,0,5"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left" IsVisible="{Binding CancelBlockBtnVisibility}"
                                ToolTip.Tip="{DynamicResource LongerTip}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <base:Icon IconType="StatusCircleBlock" FontSize="12"
                                           VerticalAlignment="Center"
                                           Foreground="White" />
                                <TextBlock Text="{DynamicResource IgnoredText}"
                                           Foreground="White"
                                           VerticalAlignment="Center"
                                           Margin="5,0,0,0" />
                            </StackPanel>
                        </Border>
                    </base:View>
                    <base:View Value="{Binding IsRegexIgnore}">
                        <Border Background="#f51837" Padding="10,5" CornerRadius="{StaticResource RadiusSmall}"
                                Margin="0,0,0,5" VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                ToolTip.Tip="{DynamicResource LongerTip}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <base:Icon IconType="StatusCircleBlock" FontSize="12" VerticalAlignment="Center"
                                           Foreground="White" />
                                <TextBlock Text="{DynamicResource MatchREIgnoredText}" Foreground="White"
                                           VerticalAlignment="Center" Margin="5,0,0,0" />
                            </StackPanel>
                        </Border>
                    </base:View>

                    <base:View Value="{Binding App.Alias}" Condition="not empty">
                        <StackPanel>
                            <TextBlock ToolTip.Tip="{DynamicResource ApplicationAlias}"
                                       Text="{Binding App.Alias}"
                                       FontSize="18" VerticalAlignment="Center" TextWrapping="WrapWithOverflow">
                                <TextBlock ToolTip.Tip="{DynamicResource ApplicationPName}">
                                    <Run Text="{Binding App.Name}" />
                                </TextBlock>
                                <Run Text="(" />
                                <TextBlock ToolTip.Tip="{DynamicResource ApplicationDescription}">
                                    <Run Text="{Binding App.Description}" />
                                </TextBlock>
                                <Run Text=")" />
                            </TextBlock>
                        </StackPanel>
                    </base:View>
                    <base:View Value="{Binding App.Alias}" Condition="empty">
                        <StackPanel>
                            <TextBlock ToolTip.Tip="{DynamicResource ApplicationPName}"
                                       Text="{Binding App.Description}"
                                       FontSize="18"
                                       VerticalAlignment="Center"
                                       TextWrapping="WrapWithOverflow" />

                            <TextBlock
                                ToolTip.Tip="{DynamicResource ApplicationDescription}"
                                Text="{Binding App.Name}" FontSize="12"
                                Foreground="Gray"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Margin="0,5,0,0" />
                        </StackPanel>
                    </base:View>

                    <TextBlock ToolTip.Tip="{DynamicResource ApplicationFilePath}"
                               Foreground="Gray"
                               Text="{Binding App.File}"
                               Margin="0,5,0,0"
                               TextWrapping="WrapWithOverflow" />

                    <!--分类-->
                    <s:Select Margin="0,10,0,0" ToolTip.Tip="{DynamicResource Classification}"
                              SelectedItem="{Binding Category,Mode=TwoWay}"
                              Options="{Binding Categorys}"
                              Padding="10,0"
                              Height="30" />
                </StackPanel>

                <Grid Grid.Column="2">
                    <base:View Condition="=False" Value="{Binding IsRegexIgnore}" HorizontalAlignment="Right">
                        <StackPanel>
                            <btn:Button Command="{Binding BlockActionCommand}"
                                        CommandParameter="block"
                                        Width="120"
                                        IsVisible="{Binding BlockBtnVisibility}"
                                        Icon="StatusCircleBlock" Content="{DynamicResource IgnoreThisApplication}" />
                            <btn:Button
                                Command="{Binding BlockActionCommand}"
                                CommandParameter="unblock" Width="120"
                                IsVisible="{Binding CancelBlockBtnVisibility}"
                                Icon="Remove" Content="{DynamicResource Unignore}" />

                        </StackPanel>
                    </base:View>


                </Grid>
            </Grid>
        </Border>

        <WrapPanel Margin="-10">
            <StackPanel Margin="10,10,0,0">
                <Grid  Margin="0,10,0,0">
                    <TextBlock Text="{DynamicResource DurationStatistics}" Foreground="#5c5c5c" FontSize="14"
                               Margin="0,20,0,0" VerticalAlignment="Center" />

                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <!-- 日期选择 -->
                        <Grid VerticalAlignment="Center">
                            <!--按天-->
                            <base:View Condition="0" Value="{Binding TabbarSelectedIndex}">
                                <s:DateSelect Date="{Binding ChartDate,Mode=TwoWay}" />
                            </base:View>
                            <!--按周-->
                            <base:View Condition="1" Value="{Binding TabbarSelectedIndex}">
                                <s:DateSelect Date="{Binding WeekDate,Mode=TwoWay}" SelectType="Week" />
                            </base:View>
                            <!--按月-->
                            <base:View Condition="2" Value="{Binding TabbarSelectedIndex}">
                                <s:DateSelect Date="{Binding MonthDate,Mode=TwoWay}" SelectType="Month" />
                            </base:View>
                            <!--按年-->
                            <base:View Condition="3" Value="{Binding TabbarSelectedIndex}">
                                <s:DateSelect Date="{Binding YearDate,Mode=TwoWay}" SelectType="Year" />
                            </base:View>
                        </Grid>

                        <!-- 周期切换 -->
                        <s:TabSwitch IsShowIcon="False"
                                     SelectedItem="{Binding SelectedPeriod,Mode=TwoWay}"
                                     Options="{Binding PeriodOptions}" />
                    </StackPanel>
                </Grid>

                <Border Margin="0,10,0,0" Width="680"
                        HorizontalAlignment="Left"
                        Background="{DynamicResource SettingPanelBgBrush}"
                        Padding="20"
                        CornerRadius="{StaticResource RadiusMedium}">

                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" Color="#000000" Opacity="0.08" OffsetX="0" OffsetY="3" />
                    </Border.Effect>

                    <StackPanel>
                        <Charts:ColumnChart IsShowCategory="False"
                                           DataMaximum="{Binding DataMaximum}"
                                           Height="305"
                                           NameIndexStart="{Binding NameIndexStart}"
                                           Data="{Binding ChartData}"
                                           Margin="0,20,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Margin="10,0,0,0" VerticalAlignment="Bottom" Width="680">
                <TextBlock Text="{DynamicResource MonthlyOverview}" Foreground="#5c5c5c" FontSize="14"
                           Margin="0,20,0,0" />

                <Border
                    Background="{DynamicResource SettingPanelBgBrush}"
                    CornerRadius="{StaticResource RadiusMedium}"
                    Padding="20,20"
                    Margin="0,10,0,0">

                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" Color="#000000" Opacity="0.08" OffsetX="0" OffsetY="3" />
                    </Border.Effect>

                    <StackPanel>
                        <Grid>
                            <DatePickerBar:DatePickerBar
                                ShowType="Month"
                                HorizontalAlignment="Left"
                                SelectedDate="{Binding Date,Mode=TwoWay}" />

                            <btn:Button ToolTip.Tip="{DynamicResource ClearAppTheMonth}"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top" Background="#f51837"
                                        Foreground="White" Width="120" Margin="0"
                                        Icon="Delete"
                                        Command="{Binding ClearSelectMonthDataCommand}"
                                        Content="{DynamicResource ClearTheMonth}" />

                        </Grid>

                        <Grid Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="256" />
                                <ColumnDefinition Width="9*" />
                            </Grid.ColumnDefinitions>

                            <Charts:MonthChart Data="{Binding Data}" HorizontalAlignment="Left" />

                            <StackPanel Grid.Column="1">
                                <Border Padding="15" CornerRadius="{StaticResource RadiusMedium}" BorderThickness="0">
                                    <Border.Background>
                                        <SolidColorBrush Color="{DynamicResource ThemeColor}" Opacity=".08" />
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="{DynamicResource ThemeColor}" Opacity=".5" />
                                    </Border.BorderBrush>
                                    <Grid>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="auto" />
                                                <RowDefinition Height="auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock FontSize="14">
                                                <Run Text="{DynamicResource AccumulatedUsageDuringTheMonth}"
                                                     Foreground="{DynamicResource SubTextBrush}" />
                                                <Run Foreground="{DynamicResource DefaultTextBrush}"
                                                     FontSize="16"
                                                     Text="{Binding Total}" />
                                            </TextBlock>
                                            <TextBlock Grid.Row="1" Margin="0,5,0,0" FontSize="14">
                                                <Run Text="{Binding LongDay}" />
                                            </TextBlock>
                                        </Grid>
                                        <base:Icon IconType="DateTimeMirrored" HorizontalAlignment="Right"
                                                   VerticalAlignment="Bottom" FontSize="30"
                                                   Foreground="{DynamicResource ThemeBrush}" Opacity=".5" />
                                    </Grid>
                                </Border>
                                <Border Margin="0,10,0,0" Padding="15" CornerRadius="{StaticResource RadiusMedium}"
                                        BorderThickness="0">
                                    <Border.Background>
                                        <SolidColorBrush Color="{DynamicResource ThemeColor}" Opacity=".08" />
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="{DynamicResource ThemeColor}" Opacity=".5" />
                                    </Border.BorderBrush>
                                    <Grid>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="auto" />
                                                <RowDefinition Height="auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Foreground="{DynamicResource SubTextBrush}"
                                                       Text="{DynamicResource ProportionDurationInTheMonth}"
                                                       FontSize="14" />

                                            <TextBlock Foreground="{DynamicResource DefaultTextBrush}"
                                                       Grid.Row="1" Margin="0,10,0,0" FontSize="24">
                                                <Run Text="{Binding Ratio}" />
                                            </TextBlock>
                                        </Grid>
                                        <base:Icon IconType="ReportDocument"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Bottom" FontSize="30"
                                                   Foreground="{DynamicResource ThemeBrush}"
                                                   Opacity=".5" />
                                    </Grid>
                                </Border>

                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </WrapPanel>

    </StackPanel>
</UserControl>
