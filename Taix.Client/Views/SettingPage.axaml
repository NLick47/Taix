<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="1250"
             xmlns:model="using:Taix.Client.ViewModels"
             x:DataType="model:SettingPageViewModel"
             xmlns:Btn="using:Taix.Client.Controls.Button"
             xmlns:select="using:Taix.Client.Controls.Select"
             xmlns:Tabbar="using:Taix.Client.Controls.Tabbar"
             xmlns:SettingPanel="using:Taix.Client.Controls.SettingPanel"
             xmlns:input="using:Taix.Client.Controls.Input"
             xmlns:base="using:Taix.Client.Controls.Base"
             xmlns:i="using:Avalonia.Xaml.Interactivity"
             xmlns:behaviors="using:Taix.Client.Behaviors"
             x:Class="Taix.Client.Views.SettingPage">
    <i:Interaction.Behaviors>
        <behaviors:ScrollTabSyncBehavior TabbarName="Tabbar"
                                         SectionPrefix="Section"
                                         ScrollViewerName="ContentScrollViewer" />
    </i:Interaction.Behaviors>

    <Grid Margin="20" RowDefinitions="Auto,*">
        <StackPanel Grid.Row="0">
            <TextBlock Text="{DynamicResource Settings}" FontSize="18" Margin="0,5,0,20" />
            <Tabbar:Tabbar x:Name="Tabbar"
                HorizontalAlignment="Left" Data="{Binding TabbarData}"
                SelectedIndex="{Binding TabbarSelectedIndex,Mode=TwoWay}" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" x:Name="ContentScrollViewer"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="SectionContainer" Margin="0,15,0,0">
                <StackPanel.Styles>
                    <Style Selector="StackPanel.section-header">
                        <Setter Property="Orientation" Value="Horizontal" />
                        <Setter Property="Margin" Value="0,0,0,10" />
                    </Style>
                    <Style Selector="Border.section-accent">
                        <Setter Property="Width" Value="4" />
                        <Setter Property="Background" Value="{DynamicResource ThemeBrush}" />
                        <Setter Property="CornerRadius" Value="2" />
                        <Setter Property="Margin" Value="0,3,10,3" />
                    </Style>
                    <Style Selector="TextBlock.section-title">
                        <Setter Property="FontSize" Value="16" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                    </Style>
                </StackPanel.Styles>

                <StackPanel x:Name="Section0">
                    <StackPanel Classes="section-header">
                        <Border Classes="section-accent" />
                        <TextBlock Classes="section-title" Text="{DynamicResource General}" />
                    </StackPanel>
                    <SettingPanel:SettingPanel Data="{Binding GeneralSettings,Mode=TwoWay}" />
                </StackPanel>

                <StackPanel x:Name="Section1" Margin="0,30,0,0">
                    <StackPanel Classes="section-header">
                        <Border Classes="section-accent" />
                        <TextBlock Classes="section-title" Text="{DynamicResource Behavior}" />
                    </StackPanel>
                    <SettingPanel:SettingPanel Data="{Binding BehaviorSettings,Mode=TwoWay}" />
                </StackPanel>

                <StackPanel x:Name="Section2" Margin="0,30,0,0">
                    <StackPanel Classes="section-header">
                        <Border Classes="section-accent" />
                        <TextBlock Classes="section-title" Text="{DynamicResource Data}" />
                    </StackPanel>
                    <Border Background="{DynamicResource SettingPanelBgBrush}" Padding="15" CornerRadius="{StaticResource RadiusSmall}"
                            Margin="0,10,0,0" BorderBrush="{DynamicResource SettingPanelBorderBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource DataRetentionDays}" FontSize="14" />
                            <TextBlock Text="{DynamicResource DataRetentionDaysDesc}" Foreground="{DynamicResource SubTextBrush}" FontSize="11" Margin="0,4,0,0" />
                            <select:TabSwitch Margin="0,12,0,0"
                                              Options="{Binding RetentionOptions}"
                                              SelectedItem="{Binding SelectedRetentionOption, Mode=TwoWay}"
                                              IsShowIcon="False" />
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,10,0,0"
                                        IsVisible="{Binding IsCustomRetention}">
                                <NumericUpDown Value="{Binding DataRetentionDays, Mode=TwoWay}" Minimum="1" Maximum="9999" Width="110" VerticalAlignment="Center" />
                                <TextBlock Text="{DynamicResource Days}" VerticalAlignment="Center" FontSize="13" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="{DynamicResource DeleteData}" Foreground="{DynamicResource DangerBrush}" FontSize="14" Margin="0,15,0,0" />
                    <Border Background="{DynamicResource SettingPanelBgBrush}" Padding="20" CornerRadius="{StaticResource RadiusSmall}"
                            Margin="0,10,0,0" BorderBrush="{DynamicResource SettingPanelBorderBrush}"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBlock Text="{DynamicResource From}" VerticalAlignment="Center" />
                            <select:DateSelect Date="{Binding DelDataStartMonthDate,Mode=TwoWay}" Margin="10,0"
                                               SelectType="Month" />
                            <TextBlock Text="{DynamicResource To}" VerticalAlignment="Center" />
                            <select:DateSelect Date="{Binding DelDataEndMonthDate,Mode=TwoWay}" Margin="10,0"
                                               SelectType="Month" />
                            <Btn:Button Margin="20,0,0,0" Icon="Delete" Content="{DynamicResource Execute}"
                                        Width="80" Background="{DynamicResource DangerBrush}"
                                        Foreground="{DynamicResource OnAccentBrush}" Command="{Binding DelDataCommand}"
                                        ToolTip.Tip="{DynamicResource DeletedAndUnrecoverable}" />
                        </StackPanel>
                    </Border>
                    <TextBlock Text="{DynamicResource ExportData}" FontSize="14" Margin="0,15,0,0" />
                    <Border Background="{DynamicResource SettingPanelBgBrush}" Padding="20" CornerRadius="{StaticResource RadiusSmall}"
                            Margin="0,10,0,0" BorderBrush="{DynamicResource SettingPanelBorderBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource ExportTo}" Foreground="{DynamicResource SubTextBrush}" FontSize="12" />
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <TextBlock Text="{DynamicResource From}" VerticalAlignment="Center" />
                                <select:DateSelect Date="{Binding ExportDataStartMonthDate,Mode=TwoWay}" Margin="10,0"
                                                   SelectType="Month" />
                                <TextBlock Text="{DynamicResource To}" VerticalAlignment="Center" />
                                <select:DateSelect Date="{Binding ExportDataEndMonthDate,Mode=TwoWay}" Margin="10,0"
                                                   SelectType="Month" />
                                <Btn:Button Margin="20,0,0,0" Icon="Share" Content="{DynamicResource Export}"
                                            Width="80" Command="{Binding ExportDataCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel x:Name="Section3" Margin="0,30,0,0">
                    <StackPanel Classes="section-header">
                        <Border Classes="section-accent" />
                        <TextBlock Classes="section-title" Text="{DynamicResource Shortcuts}" />
                    </StackPanel>
                    <Border Background="{DynamicResource SettingPanelBgBrush}"
                            CornerRadius="{StaticResource RadiusSmall}"
                            Margin="0,10,0,0"
                            BorderBrush="{DynamicResource SettingPanelBorderBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <StackPanel.Styles>
                                <Style Selector="Grid.shortcut-row">
                                    <Setter Property="Margin" Value="20,16" />
                                </Style>
                                <Style Selector="Border.shortcut-divider">
                                    <Setter Property="Height" Value="1" />
                                    <Setter Property="Margin" Value="20,0" />
                                    <Setter Property="Background" Value="{DynamicResource SettingPanelBorderBrush}" />
                                </Style>
                                <Style Selector="TextBlock.shortcut-title">
                                    <Setter Property="FontSize" Value="13" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </Style>
                                <Style Selector="TextBlock.shortcut-desc">
                                    <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}" />
                                    <Setter Property="FontSize" Value="11" />
                                </Style>
                            </StackPanel.Styles>

                            <!-- 行 1：刷新 -->
                            <Grid Classes="shortcut-row" ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0"
                                            Margin="0,0,16,0"
                                            VerticalAlignment="Center"
                                            Spacing="3">
                                    <TextBlock Classes="shortcut-title" Text="{DynamicResource RefreshShortcut}" />
                                    <TextBlock Classes="shortcut-desc" Text="{DynamicResource RefreshShortcutDesc}" />
                                </StackPanel>
                                <input:KeyGestureCapture Grid.Column="1"
                                                         VerticalAlignment="Center"
                                                         Placeholder="{DynamicResource PressKeysHint}"
                                                         DefaultValue="F5"
                                                         Value="{Binding RefreshShortcut, Mode=TwoWay}" />
                            </Grid>

                            <Border Classes="shortcut-divider" />

                            <!-- 行 2：搜索 -->
                            <Grid Classes="shortcut-row" ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0"
                                            Margin="0,0,16,0"
                                            VerticalAlignment="Center"
                                            Spacing="3">
                                    <TextBlock Classes="shortcut-title" Text="{DynamicResource SearchShortcut}" />
                                    <TextBlock Classes="shortcut-desc" Text="{DynamicResource SearchShortcutDesc}" />
                                </StackPanel>
                                <input:KeyGestureCapture Grid.Column="1"
                                                         VerticalAlignment="Center"
                                                         Placeholder="{DynamicResource PressKeysHint}"
                                                         DefaultValue="Ctrl+K"
                                                         Value="{Binding SearchShortcut, Mode=TwoWay}" />
                            </Grid>

                            <Border Classes="shortcut-divider" />

                            <!-- 行 3：返回上一页 -->
                            <Grid Classes="shortcut-row" ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0"
                                            Margin="0,0,16,0"
                                            VerticalAlignment="Center"
                                            Spacing="3">
                                    <TextBlock Classes="shortcut-title" Text="{DynamicResource NavigateBackShortcut}" />
                                    <TextBlock Classes="shortcut-desc" Text="{DynamicResource NavigateBackShortcutDesc}" />
                                </StackPanel>
                                <input:KeyGestureCapture Grid.Column="1"
                                                         VerticalAlignment="Center"
                                                         Placeholder="{DynamicResource PressKeysHint}"
                                                         DefaultValue="Alt+Left"
                                                         Value="{Binding NavigateBackShortcut, Mode=TwoWay}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel x:Name="Section4" Margin="0,30,0,0">
                    <StackPanel Classes="section-header">
                        <Border Classes="section-accent" />
                        <TextBlock Classes="section-title" Text="{DynamicResource About}" />
                    </StackPanel>
                    <Border Background="{DynamicResource SettingPanelBgBrush}" Padding="20" CornerRadius="{StaticResource RadiusSmall}">
                        <StackPanel HorizontalAlignment="Left">
                            <Image Width="25" Source="/Resources/Icons/tai.ico" HorizontalAlignment="Left" />
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <TextBlock VerticalAlignment="Center">
                                    <Run Text="Taix" />
                                    <Run Text="{DynamicResource Version}" />
                                    <Run Text="{Binding Version}" />
                                </TextBlock>
                                <Btn:Button IsVisible="{Binding CheckUpdateBtnVisibility}"
                                            Command="{Binding CheckUpdate}"
                                            Margin="20,0,0,0"
                                            VerticalAlignment="Center" Width="120"
                                            Icon="SetlockScreen" Content="{DynamicResource CheckUpdate}" />
                            </StackPanel>
                            <TextBlock Margin="0,30,0,0">

                                <HyperlinkButton Command="{Binding OpenURL}"
                                                 CommandParameter="https://github.com/Planshit/Tai/discussions/279"
                                                 Content="{DynamicResource PlugIn}" />
                            </TextBlock>
                            <TextBlock Margin="0,15,0,0">
                                <Run Text="{DynamicResource OpenSource}" />
                                <HyperlinkButton Command="{Binding OpenURL}"
                                                 CommandParameter="https://github.com/NLick47/Taix">
                                    https://github.com/NLick47/Taix
                                </HyperlinkButton>
                            </TextBlock>
                            <TextBlock Margin="0,5,0,0">
                                <Run Text="{DynamicResource Discuss}" />
                                <HyperlinkButton Command="{Binding OpenURL}"
                                                 CommandParameter="https://github.com/NLick47/Taix/discussions">
                                    https://github.com/NLick47/Taix/discussions
                                </HyperlinkButton>
                            </TextBlock>

                            <TextBlock Margin="0,10,0,0">
                                <Run Text="{DynamicResource ExternalDeclaration}" />
                            </TextBlock>
                            <TextBlock Foreground="{DynamicResource SubTextBrush}" Margin="0,5,0,0">
                                <Run Text="Icon" />
                                <Run Text="{DynamicResource FromMicrosoft}" />
                                <Run Text="Emoji}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
