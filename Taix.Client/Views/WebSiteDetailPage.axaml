<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             Foreground="{DynamicResource StandardTextBrush}"
             xmlns:converter="using:Taix.Client.Controls.Converters"
             xmlns:base="using:Taix.Client.Controls.Base"
             xmlns:charts="using:Taix.Client.Controls.Charts"
             xmlns:select="using:Taix.Client.Controls.Select"
             xmlns:model="using:Taix.Client.ViewModels"
             x:DataType="model:WebSiteDetailPageViewModel"
             x:Class="Taix.Client.Views.WebSiteDetailPage">
    <UserControl.Resources>
        <converter:TimeConverter x:Key="TimeConverter" />
        <converter:DateTimeConverter x:Key="DateTimeConverter" />
        <converter:GetCountConverter x:Key="GetCountConverter" />
    </UserControl.Resources>

    <StackPanel Margin="20">
        <Grid ColumnDefinitions="Auto,*" Margin="0,5,0,20">
            <TextBlock Grid.Column="0" Text="{DynamicResource Website}"
                       FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
        </Grid>

        <!--基本信息-->
        <Border
            Background="{DynamicResource SettingPanelBgBrush}"
            CornerRadius="{StaticResource RadiusMedium}"
            Padding="24,20"
            ContextMenu="{Binding WebSiteContextMenu}">

            <Grid ColumnDefinitions="Auto,*">

                <Border Grid.Column="0" Width="56" Height="56"
                        CornerRadius="14" Margin="0,0,18,0"
                        Background="{DynamicResource ListItemIconBgBrush}"
                        VerticalAlignment="Center">
                    <base:Img URL="{Binding WebSite.IconFile}"
                              DecodeWidth="64"
                              Width="32" Height="32"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">

                    <base:View Value="{Binding IsIgnore}">
                        <Border Background="{DynamicResource DangerBrush}" Padding="8,3" CornerRadius="{StaticResource RadiusSmall}"
                                Margin="0,0,0,6"
                                HorizontalAlignment="Left"
                                ToolTip.Tip="{DynamicResource LongerWebSiteTip}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <base:Icon IconType="StatusCircleBlock" FontSize="11" VerticalAlignment="Center"
                                           Foreground="{DynamicResource OnAccentBrush}" />
                                <TextBlock Text="{DynamicResource IgnoredText}"
                                           FontSize="11"
                                           Foreground="{DynamicResource OnAccentBrush}"
                                           VerticalAlignment="Center" Margin="4,0,0,0" />
                            </StackPanel>
                        </Border>
                    </base:View>

                    <base:View Value="{Binding WebSite.Alias}" Condition="not empty">
                        <TextBlock ToolTip.Tip="{DynamicResource ApplicationAlias}"
                                   Text="{Binding WebSite.Alias}"
                                   FontSize="20" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                    </base:View>
                    <base:View Value="{Binding WebSite.Alias}" Condition="empty">
                        <TextBlock ToolTip.Tip="{DynamicResource WebSiteTitle}"
                                   Text="{Binding WebSite.Title}"
                                   FontSize="20" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                    </base:View>

                    <base:View Value="{Binding WebSite.Alias}" Condition="not empty">
                        <TextBlock FontSize="12" Foreground="{DynamicResource SubTextBrush}"
                                   Margin="0,3,0,0"
                                   TextTrimming="CharacterEllipsis">
                            <Run Text="{Binding WebSite.Domain}" />
                            <Run Text=" · " />
                            <Run Text="{Binding WebSite.Title}" />
                        </TextBlock>
                    </base:View>
                    <base:View Value="{Binding WebSite.Alias}" Condition="empty">
                        <TextBlock ToolTip.Tip="{DynamicResource Domain}"
                                   Text="{Binding WebSite.Domain}" FontSize="12"
                                   Foreground="{DynamicResource SubTextBrush}"
                                   Margin="0,3,0,0" />
                    </base:View>

                    <select:Select Margin="0,12,0,0"
                                   HorizontalAlignment="Left"
                                   ToolTip.Tip="{DynamicResource WebSiteClassification}"
                                   SelectedItem="{Binding Category,Mode=TwoWay}"
                                   Options="{Binding Categories}"
                                   Padding="10,0" Height="30" />
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Margin="0,12,0,0" Spacing="16">

            <!--统计图表-->
            <Border Background="{DynamicResource SettingPanelBgBrush}"
                    CornerRadius="{StaticResource RadiusMedium}">
                <StackPanel>
                    <Grid Margin="20,16,20,12" ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="{DynamicResource DurationStatistics}"
                                   FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <Grid VerticalAlignment="Center">
                                <base:View Condition="0" Value="{Binding TabbarSelectedIndex}">
                                    <select:DateSelect Date="{Binding ChartDate,Mode=TwoWay}" />
                                </base:View>
                                <base:View Condition="1" Value="{Binding TabbarSelectedIndex}">
                                    <select:DateSelect Date="{Binding WeekDate,Mode=TwoWay}" SelectType="Week" />
                                </base:View>
                                <base:View Condition="2" Value="{Binding TabbarSelectedIndex}">
                                    <select:DateSelect Date="{Binding MonthDate,Mode=TwoWay}" SelectType="Month" />
                                </base:View>
                                <base:View Condition="3" Value="{Binding TabbarSelectedIndex}">
                                    <select:DateSelect Date="{Binding YearDate,Mode=TwoWay}" SelectType="Year" />
                                </base:View>
                            </Grid>
                            <select:TabSwitch IsShowIcon="False"
                                              SelectedItem="{Binding SelectedPeriod,Mode=TwoWay}"
                                              Options="{Binding PeriodOptions}" />
                        </StackPanel>
                    </Grid>

                    <Border Height="1" Background="{DynamicResource SettingPanelSpliteLineBrush}" Opacity="0.5" />

                    <charts:ColumnChart IsShowCategory="False"
                                        Height="300"
                                        NameIndexStart="{Binding NameIndexStart}"
                                        Data="{Binding ChartData}"
                                        Margin="20,16,20,20" />
                </StackPanel>
            </Border>

            <!--浏览记录-->
            <Border Background="{DynamicResource SettingPanelBgBrush}"
                    CornerRadius="{StaticResource RadiusMedium}">
                <StackPanel>
                    <Grid Margin="20,16,20,12" ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="{DynamicResource ViewDetails}"
                                   FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                   FontSize="12" Foreground="{DynamicResource SubTextBrush}">
                            <Run Text="{Binding WebPageData,Converter={StaticResource GetCountConverter}}" />
                            <Run Text="{DynamicResource MultipleWebsites}" />
                        </TextBlock>
                    </Grid>

                    <Border Height="1" Background="{DynamicResource SettingPanelSpliteLineBrush}" Opacity="0.5" />

                    <ListBox Margin="8" MaxHeight="800" Background="Transparent" BorderThickness="0" Padding="0"
                             ItemsSource="{Binding WebPageData}"
                             SelectedItem="{Binding WebPageSelectedItem,Mode=TwoWay}">

                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{DynamicResource OpenWebPage}"
                                          Command="{Binding PageCommand}"
                                          CommandParameter="Open" />
                                <Separator />
                                <MenuItem Header="{DynamicResource CopyURL}" Command="{Binding PageCommand}"
                                          CommandParameter="CopyURL" />
                                <MenuItem Header="{DynamicResource Title}" Command="{Binding PageCommand}"
                                          CommandParameter="CopyTitle" />
                            </ContextMenu>
                        </ListBox.ContextMenu>

                        <ListBox.Styles>
                            <Style Selector="ListBox">
                                <Setter Property="Template">
                                    <ControlTemplate>
                                        <ScrollViewer>
                                            <ItemsPresenter
                                                ItemsPanel="{TemplateBinding ItemsPanel}" />
                                        </ScrollViewer>
                                    </ControlTemplate>
                                </Setter>
                            </Style>

                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,2" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Template">
                                    <ControlTemplate>
                                        <Grid>
                                            <Border x:Name="Border"
                                                    Background="Transparent"
                                                    Padding="12,9,12,9"
                                                    CornerRadius="{StaticResource RadiusSmall}">
                                                <ContentPresenter x:Name="PART_ContentPresenter"
                                                    Background="Transparent"
                                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                                    Content="{TemplateBinding Content}" />
                                            </Border>
                                            <Border x:Name="Accent"
                                                    HorizontalAlignment="Left"
                                                    Width="3" Height="20"
                                                    CornerRadius="0,2,2,0"
                                                    Background="{DynamicResource ListItemAccentBrush}"
                                                    IsVisible="False" />
                                        </Grid>
                                    </ControlTemplate>
                                </Setter>

                                <!--压住 SimpleTheme 默认的 ContentPresenter 背景，避免悬浮/选中时叠出第二层灰色-->
                                <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                                <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                                <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                                <Style Selector="^:selected /template/ ContentPresenter#PART_ContentPresenter">
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                                <Style Selector="^:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>

                                <Style Selector="^:pointerover /template/ Border#Border">
                                    <Setter Property="Background"
                                            Value="{DynamicResource ListItemHoverBrush}" />
                                </Style>

                                <Style Selector="^:pressed /template/ Border#Border">
                                    <Setter Property="Background"
                                            Value="{DynamicResource ListItemPressedBrush}" />
                                </Style>

                                <Style Selector="^:selected /template/ Border#Border">
                                    <Setter Property="Background"
                                            Value="{DynamicResource ListItemSelectedBrush}" />
                                </Style>
                                <Style Selector="^:selected /template/ Border#Accent">
                                    <Setter Property="IsVisible" Value="True" />
                                </Style>

                                <Style Selector="^:selected:pointerover /template/ Border#Border">
                                    <Setter Property="Background"
                                            Value="{DynamicResource ListItemSelectedHoverBrush}" />
                                </Style>
                            </Style>
                        </ListBox.Styles>

                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                                    <Border Grid.Column="0" Width="28" Height="28"
                                            CornerRadius="6"
                                            Background="{DynamicResource ListItemIconBgBrush}"
                                            VerticalAlignment="Center">
                                        <base:Img Width="16" Height="16" DecodeWidth="64"
                                                  URL="{Binding Url.IconFile}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Center">
                                        <TextBlock FontSize="14" FontWeight="Medium"
                                                   Foreground="{DynamicResource DefaultTextBrush}"
                                                   Text="{Binding Url.Title}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Margin="0,3,0,0" FontSize="12"
                                                   Text="{Binding Url.Url}"
                                                   Foreground="{DynamicResource SubTextBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Orientation="Vertical"
                                                HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Border HorizontalAlignment="Right"
                                                Padding="8,3" CornerRadius="{StaticResource RadiusSmall}"
                                                ToolTip.Tip="{DynamicResource Duration}">
                                            <Border.Background>
                                                <SolidColorBrush
                                                    Color="{DynamicResource ThemeColor}"
                                                    Opacity=".15" />
                                            </Border.Background>
                                            <TextBlock FontSize="12" FontWeight="Medium"
                                                       Foreground="{DynamicResource ThemeBrush}"
                                                       Text="{Binding Duration,Converter={StaticResource TimeConverter}}" />
                                        </Border>
                                        <TextBlock Margin="0,4,2,0" FontSize="11"
                                                   HorizontalAlignment="Right"
                                                   Foreground="{DynamicResource SubTextBrush}"
                                                   Text="{Binding LogTime,Converter={StaticResource DateTimeConverter}}"
                                                   ToolTip.Tip="{DynamicResource LogTime}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </StackPanel>
    </StackPanel>
</UserControl>
