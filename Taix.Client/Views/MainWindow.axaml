<ui:DefaultWindow xmlns="https://github.com/avaloniaui"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:vm="using:Taix.Client.ViewModels"
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                  mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
                  x:Class="Taix.Client.Views.MainWindow"
                  xmlns:ui="using:Taix.Client.Controls.Window"
                  x:DataType="vm:MainViewModel"
                  IconSource="/Resources/Icons/tai32.ico"
                  xmlns:na="using:Taix.Client.Controls.Navigation"
                  xmlns:control="using:Taix.Client.Controls"
                  xmlns:base="using:Taix.Client.Controls.Base"
                  xmlns:models="using:Taix.Client.Models"
                  PageContainer="{Binding PageContainer}"
                  xmlns:i="using:Avalonia.Xaml.Interactivity"
                  xmlns:ia="using:Avalonia.Xaml.Interactions.Core"
                  IsShowToast="{Binding IsShowToast,Mode=TwoWay}"
                  ToastContent="{Binding ToastContent,Mode=TwoWay}"
                  ToastIcon="{Binding ToastIcon}"
                  ToastType="{Binding ToastType}"
                  Height="553" Width="815" MinHeight="553" MinWidth="814"
                  Title="{Binding Title}">
    <Interaction.Behaviors>
        <EventTriggerBehavior EventName="Loaded">
            <InvokeCommandAction
                Command="{Binding LoadDefaultPageCommand}" />
        </EventTriggerBehavior>
    </Interaction.Behaviors>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Width="80" Margin="0,32,0,15"> <DockPanel>
                <StackPanel DockPanel.Dock="Bottom" 
                            VerticalAlignment="Bottom" 
                            Spacing="4" 
                            Margin="0,10,0,0">
    
                    <Border Width="10" Height="10"
                            CornerRadius="5"
                            Background="#999999"
                            HorizontalAlignment="Center"
                            ToolTip.Tip="{DynamicResource ConnectionStatusChecking}">
    
                        <i:Interaction.Behaviors>
                            <ia:DataTriggerBehavior Binding="{Binding ConnectionStatus}" Value="{x:Static models:ConnectionStatus.Connected}">
                                <ia:ChangePropertyAction PropertyName="Background" Value="#24bf5f"/>
                                <ia:ChangePropertyAction PropertyName="ToolTip.Tip" Value="{DynamicResource ConnectionStatusConnected}"/>
                            </ia:DataTriggerBehavior>
                            <ia:DataTriggerBehavior Binding="{Binding ConnectionStatus}" Value="{x:Static models:ConnectionStatus.Disconnected}">
                                <ia:ChangePropertyAction PropertyName="Background" Value="#f51837"/>
                                <ia:ChangePropertyAction PropertyName="ToolTip.Tip" Value="{DynamicResource ConnectionStatusDisconnected}"/>
                            </ia:DataTriggerBehavior>
                            <ia:DataTriggerBehavior Binding="{Binding ConnectionStatus}" Value="{x:Static models:ConnectionStatus.Checking}">
                                <ia:ChangePropertyAction PropertyName="Background" Value="#999999"/>
                                <ia:ChangePropertyAction PropertyName="ToolTip.Tip" Value="{DynamicResource ConnectionStatusChecking}"/>
                            </ia:DataTriggerBehavior>
                        </i:Interaction.Behaviors>

                        <Border.Styles>
                            <Style Selector="Border">
                                <Style.Animations>
                                    <Animation Duration="0:0:4" 
                                               IterationCount="INFINITE">
                    
                                        <KeyFrame Cue="0%">
                                            <Setter Property="Opacity" Value="1.0" />
                                        </KeyFrame>
                    
                                        <KeyFrame Cue="50%">
                                            <Setter Property="Opacity" Value="0.8" />
                                        </KeyFrame>
                    
                                        <KeyFrame Cue="100%">
                                            <Setter Property="Opacity" Value="1.0" />
                                        </KeyFrame>
                                    </Animation>
                                </Style.Animations>
                            </Style>
                        </Border.Styles>
                    </Border>
                </StackPanel>

                <na:Navigation x:Name="Navigation" 
                               Width="80"
                               Data="{Binding Items,Mode=TwoWay}"
                               SelectedItem="{Binding NavSelectedItem,Mode=TwoWay}">

                    <i:Interaction.Behaviors>
                        <ia:EventTriggerBehavior EventName="OnSelected">
                            <ia:InvokeCommandAction Command="{Binding OnSelectedCommand}"
                                                    CommandParameter="{Binding #Navigation}" />
                        </ia:EventTriggerBehavior>
                    </i:Interaction.Behaviors>

                    <na:Navigation.BottomExtContent>
                        <na:NavigationItem Icon="Settings"
                                           Title="{DynamicResource SideSetting}"
                                           Uri="SettingsPage"
                                           Command="{Binding GotoPageCommand}"
                                           CommandParameter="SettingPage" />
                    </na:Navigation.BottomExtContent>
                </na:Navigation>
            </DockPanel>
        </Grid>

        <Border Grid.Column="1" Background="{DynamicResource WindowContentBackground}" Margin="0,40,10,10"
                CornerRadius="5"
                BorderThickness="1,1,1,1"
                BorderBrush="{DynamicResource WindowContentBorder}" ClipToBounds="True">
            <control:PageContainer IndexUriList="{Binding IndexUriList}"
                                   Instance="{Binding PageContainer,Mode=TwoWay}"
                                   Uri="{Binding Uri,Mode=TwoWay}"
                                   Title="{Binding Title,Mode=TwoWay}" />
        </Border>
    </Grid>


</ui:DefaultWindow>