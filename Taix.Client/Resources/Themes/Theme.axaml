<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">
            <!--【主题颜色】-->
            <Color x:Key="ThemeColor">#FF8780F7</Color>

            <!--鼠标经过背景颜色-->
            <Color x:Key="HoverBackgroundColor">#4d4d4d</Color>

            <!--【通用笔刷】-->
            <!--主题颜色笔刷-->
            <SolidColorBrush x:Key="ThemeBrush" Color="{StaticResource ThemeColor}" />
            <!---鼠标经过背景颜色-->
            <SolidColorBrush x:Key="HoverBackgroundBrush" Color="{StaticResource HoverBackgroundColor}" />
            <!--标准背景颜色-->
            <SolidColorBrush x:Key="StandardBackgroundBrush" Color="#3e3e3e" />
            <SolidColorBrush x:Key="StandardBackgroundBrush2" Color="#3e3e3e" />

            <!--【窗口】-->
            <!--窗口边框颜色-->
            <SolidColorBrush x:Key="WindowBorderBrush" Color="#323232" />

            <SolidColorBrush x:Key="StandardTextBrush" Color="#ffffff" />
            <SolidColorBrush x:Key="SubTextBrush" Color="#ccc" />


            <SolidColorBrush x:Key="Background" Color="#161616" />
            <!--窗口背景颜色-->
            <!--<LinearGradientBrush x:Key="WindowBackground" >
        <GradientStop Color="#161616" Offset="0"/>
        <GradientStop Color="#161616" Offset="0.8"/>
        <GradientStop Color="#FF14104A" Offset="1"/>
    </LinearGradientBrush>-->
            <LinearGradientBrush x:Key="WindowBackground" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#131315" Offset="0" />
                <GradientStop Color="#1a1a1e" Offset="0.4" />
                <GradientStop Color="#18181c" Offset="0.8" />
                <GradientStop Color="{DynamicResource ThemeColor}" Offset="1.3" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="WindowContentBackground" Color="#FF383636" Opacity=".5" />
            <SolidColorBrush x:Key="WindowContentBorder" Color="#FF121010" />
            <SolidColorBrush x:Key="CardBorder" Color="Transparent" />
            <SolidColorBrush x:Key="WindowGlassHighlightBrush" Color="#ffffff" Opacity="0.06" />
            <SolidColorBrush x:Key="WindowBackgroundSolid" Color="#131315" />

            <!--导航栏-->
            <Color x:Key="NavSelectedColor">#313131</Color>
            <SolidColorBrush x:Key="NavSelectedBrush" Color="{StaticResource NavSelectedColor}" />

            <Color x:Key="NavUnselectedTextColor">#FFAFAFAF</Color>
            <SolidColorBrush x:Key="NavUnselectedTextBrush" Color="{StaticResource NavUnselectedTextColor}" />

            <!--导航栏毛玻璃效果-->
            <SolidColorBrush x:Key="NavGlassBackgroundBrush" Color="#121212" Opacity="0.28" />
            <SolidColorBrush x:Key="NavGlassBorderBrush" Color="#ffffff" Opacity="0.08" />
            <SolidColorBrush x:Key="NavSelectedGlassBrush" Color="{DynamicResource ThemeColor}" Opacity="0.18" />
            <SolidColorBrush x:Key="NavSelectedGlassBorderBrush" Color="{DynamicResource ThemeColor}" Opacity="0.22" />
            <SolidColorBrush x:Key="NavHoverGlassBrush" Color="#ffffff" Opacity="0.06" />

            <!--设置面板-->
            <Color x:Key="SettingPanelBgColor">#323232</Color>
            <SolidColorBrush x:Key="SettingPanelBgBrush" Color="{StaticResource SettingPanelBgColor}" />
            <Color x:Key="SettingPanelBorderColor">#232323</Color>
            <SolidColorBrush x:Key="SettingPanelBorderBrush" Color="{StaticResource SettingPanelBorderColor}" />
            <Color x:Key="SettingPanelSpliteLineColor">#706f6f</Color>
            <SolidColorBrush x:Key="SettingPanelSpliteLineBrush" Color="{StaticResource SettingPanelSpliteLineColor}" />

            <!--白色背景文字颜色-->
            <Color x:Key="WhiteBgTextColor">#ccc</Color>
            <SolidColorBrush x:Key="WhiteBgTextBrush" Color="{StaticResource WhiteBgTextColor}" />

            <!--默认基础文字颜色-->
            <Color x:Key="DefaultTextColor">#e7e7e7</Color>
            <SolidColorBrush x:Key="DefaultTextBrush" Color="{StaticResource DefaultTextColor}" />

            <!--列表-->
            <Color x:Key="ListItemIconBgColor">#3e3e3e</Color>
            <SolidColorBrush x:Key="ListItemIconBgBrush" Color="{StaticResource ListItemIconBgColor}" />

            <Color x:Key="BaseListItemBgColor">#3e3e3e</Color>
            <SolidColorBrush x:Key="BaseListItemBgBrush" Color="{StaticResource BaseListItemBgColor}" />
            <Color x:Key="BaseListItemHoverBgColor">#4d4d4d</Color>

            <!--日期选择控件-->
            <Color x:Key="DatePickerItemBgColor">#5A5A5A</Color>
            <SolidColorBrush x:Key="DatePickerItemBgBrush" Color="{StaticResource DatePickerItemBgColor}" />

            <!--月热力图控件-->
            <Color x:Key="ChartMonthGridItemBgColor">#7F777777</Color>
            <SolidColorBrush x:Key="ChartMonthGridItemBgBrush" Color="{StaticResource ChartMonthGridItemBgColor}" />

            <!--弹出层边框-->
            <Color x:Key="PopupBorderColor">#3c3b3b</Color>
            <SolidColorBrush x:Key="PopupBorderBrush" Color="{StaticResource PopupBorderColor}" />
            <Color x:Key="PopupBackgroundColor">#2B2B2B</Color>
            <SolidColorBrush x:Key="PopupBackgroundBrush" Color="{StaticResource PopupBackgroundColor}" />

            <!--标题栏按钮-->
            <Color x:Key="TitleBarBtnColor">#ffffff</Color>
            <SolidColorBrush x:Key="TitleBarBtnBrush" Color="{StaticResource TitleBarBtnColor}" />

            <!--分割线颜色-->
            <Color x:Key="SeparatorColor">#525151</Color>
            <SolidColorBrush x:Key="SeparatorBrush" Color="{StaticResource SeparatorColor}" />

            <!--上下文菜单-->
            <Color x:Key="ContextBorderColor">#3c3b3b</Color>
            <SolidColorBrush x:Key="ContextBorderBrush" Color="{StaticResource ContextBorderColor}" />

            <!--图表边框-->
            <Color x:Key="ChartColBorderColor">#7e7e7e</Color>
            <SolidColorBrush x:Key="ChartColBorderBrush" Color="{StaticResource ChartColBorderColor}" />

            <!--分类页面-->
            <Color x:Key="CategoryAppNumBgColor">#646464</Color>
            <SolidColorBrush x:Key="CategoryAppNumBgBrush" Color="{StaticResource CategoryAppNumBgColor}" />

            <!--分类页卡片玻璃效果-->
            <SolidColorBrush x:Key="CategoryCardGlassBgBrush" Color="#ffffff" Opacity="0.08" />
            <SolidColorBrush x:Key="CategoryCardGlassBorderBrush" Color="#ffffff" Opacity="0.30" />
            <SolidColorBrush x:Key="CategoryCardHoverGlassBrush" Color="#ffffff" Opacity="0.15" />
            <SolidColorBrush x:Key="CategoryCardHoverBorderBrush" Color="{DynamicResource ThemeColor}" Opacity="0.55" />

            <!--Chart 卡片玻璃效果-->
            <SolidColorBrush x:Key="ChartCardGlassBgBrush" Color="#ffffff" Opacity="0.06" />
            <SolidColorBrush x:Key="ChartCardGlassBorderBrush" Color="#ffffff" Opacity="0.12" />
            <SolidColorBrush x:Key="ChartCardHoverGlassBgBrush" Color="#ffffff" Opacity="0.10" />
            <SolidColorBrush x:Key="ChartCardHoverBorderBrush" Color="{DynamicResource ThemeColor}" Opacity="0.50" />

            <!--Chart 卡片药丸标签-->
            <SolidColorBrush x:Key="ChartCardPillBgBrush" Color="{DynamicResource ThemeColor}" Opacity="0.25" />
            <SolidColorBrush x:Key="ChartCardPillTextBrush" Color="#ffffff" />

            <!--输入框-->
            <Color x:Key="InputBoxBgColor">#3e3e3e</Color>
            <SolidColorBrush x:Key="InputBoxBgBrush" Color="{StaticResource InputBoxBgColor}" />
            <Color x:Key="InputBoxHoverColor">#4d4d4d</Color>
            <SolidColorBrush x:Key="InputBoxHoverBrush" Color="{StaticResource InputBoxHoverColor}" />
            <Color x:Key="InputBoxFocusedBgColor">#4F4E4E</Color>
            <SolidColorBrush x:Key="InputBoxFocusedBgBrush" Color="{StaticResource InputBoxFocusedBgColor}" />

            <!--expander-->
            <Color x:Key="ExpanderBgColor">#323232</Color>
            <SolidColorBrush x:Key="ExpanderBgBrush" Color="{StaticResource ExpanderBgColor}" />
            <Color x:Key="ExpanderContentBgColor">#2e2e2e</Color>
            <SolidColorBrush x:Key="ExpanderContentBgBrush" Color="{StaticResource ExpanderContentBgColor}" />

            <!--占位框-->
            <Color x:Key="PlaceholderRectBgColor">#323232</Color>
            <SolidColorBrush x:Key="PlaceholderRectBgBrush" Color="{StaticResource PlaceholderRectBgColor}" />
            <Color x:Key="PlaceholderRectBgFlashColor">#4d4d4d</Color>
            <SolidColorBrush x:Key="PlaceholderRectBgFlashBrush" Color="{StaticResource PlaceholderRectBgFlashColor}" />

            <Color x:Key="DisabledTextColor">#504f4f</Color>
            <SolidColorBrush x:Key="DisabledTextBrush" Color="{StaticResource DisabledTextColor}" />

            <!--滚动条-->
            <Color x:Key="ScrollBarColor">#a0a0a0</Color>
            <SolidColorBrush x:Key="ScrollBarBrush" Color="{StaticResource ScrollBarColor}" />

            <!--列表图表-->
            <Color x:Key="ChartTypeListProgressBarColor">#7F777777</Color>
            <SolidColorBrush x:Key="ChartTypeListProgressBarBrush"
                             Color="{StaticResource ChartTypeListProgressBarColor}" />

            <!--危险颜色-->
            <Color x:Key="DangerColor">#f51837</Color>
            <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />

            <!--提示颜色-->
            <Color x:Key="WarningColor">#FFC408</Color>
            <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
            
            <SolidColorBrush x:Key="GrayDark" Color="#1e1e20" Opacity="0.55" />
            
            <Color x:Key="TabOptionTextColor">#9CA3AF</Color>
            <Color x:Key="TabOptionTextCheckedColor">White</Color>
            <SolidColorBrush x:Key="TabOptionHoverBrush" Color="#2a2a2e" />
            <SolidColorBrush x:Key="TabOptionSelectedBrush" Color="{DynamicResource ThemeColor}" Opacity="0.35" />
            <SolidColorBrush x:Key="TabOptionSelectedBorderBrush" Color="{DynamicResource ThemeColor}" Opacity="0.50" />

            <!-- 时间轴 -->
            <SolidColorBrush x:Key="TimelineBgBrush" Color="#0d1117" />
            <SolidColorBrush x:Key="TimelineBorderBrush" Color="#21262d" />
            <SolidColorBrush x:Key="TimelineHeaderBgBrush" Color="#161b22" Opacity="0.7" />
            <SolidColorBrush x:Key="TimelineInactiveBrush" Color="#30363d" />
            <SolidColorBrush x:Key="TimelineTickMajorBrush" Color="#30363d" />
            <SolidColorBrush x:Key="TimelineTickHalfBrush" Color="#21262d" />
            <SolidColorBrush x:Key="TimelineTickQuarterBrush" Color="#1a1f27" />
            <SolidColorBrush x:Key="TimelineTickTextBrush" Color="#8b949e" />
            <SolidColorBrush x:Key="TimelineTimeLabelBrush" Color="#8b949e" Opacity="0.85" />
            <SolidColorBrush x:Key="TimelineNowBrush" Color="#58a6ff" />
            <SolidColorBrush x:Key="TimelineSelectBgBrush" Color="#58a6ff" Opacity="0.22" />
            <SolidColorBrush x:Key="TimelineSelectBorderBrush" Color="#58a6ff" Opacity="0.85" />
            <SolidColorBrush x:Key="TimelineTipBgBrush" Color="#161b22" />
            <SolidColorBrush x:Key="TimelineTipBorderBrush" Color="#30363d" />
            <SolidColorBrush x:Key="TimelineTipTextBrush" Color="#ffffff" />
            <SolidColorBrush x:Key="TimelineTipSubBrush" Color="#8b949e" />
            <SolidColorBrush x:Key="TimelineTrackBgBrush" Color="#252525" />
            <SolidColorBrush x:Key="TimelineTooltipShadowBrush" Color="#000000" Opacity="0.5" />
            <Color x:Key="TimelineIdleColor">#484f58</Color>
            <Color x:Key="TimelineDefaultColor">#888888</Color>
            <SolidColorBrush x:Key="TimelineNowDotOuterBrush" Color="#ffffff" />

            <!-- 时间轴时段背景 -->
            <SolidColorBrush x:Key="TimelinePeriodNightBgBrush" Color="#14182e" />
            <SolidColorBrush x:Key="TimelinePeriodMorningBgBrush" Color="#142014" />
            <SolidColorBrush x:Key="TimelinePeriodNoonBgBrush" Color="#1c1c24" />
            <SolidColorBrush x:Key="TimelinePeriodAfternoonBgBrush" Color="#241c14" />
            <SolidColorBrush x:Key="TimelinePeriodEveningBgBrush" Color="#1c1424" />

            <!-- 时间轴框选 -->
            <SolidColorBrush x:Key="TimelineSelectionMaskBrush" Color="#000000" Opacity="0.5" />
            <SolidColorBrush x:Key="TimelineSelectionBorderBrush" Color="#ffffff" />
            <SolidColorBrush x:Key="TimelineSelectionGlowBrush" Color="#ffffff" Opacity="0.12" />
            <SolidColorBrush x:Key="TimelineSelectionHandleBrush" Color="#ffffff" />
            <SolidColorBrush x:Key="TimelineSelectionHandleBorderBrush" Color="#58a6ff" />
            <SolidColorBrush x:Key="TimelineSelectionLabelBgBrush" Color="#161b22" />
            <SolidColorBrush x:Key="TimelineSelectionLabelTextBrush" Color="#ffffff" />

            <!-- 多轨道时间轴 -->
            <SolidColorBrush x:Key="MultiTrackRowBgBrush" Color="#2a2a35" />
            <SolidColorBrush x:Key="MultiTrackRowBorderBrush" Color="#3a3a48" />
            <SolidColorBrush x:Key="MultiTrackIconBgBrush" Color="#363642" />
            <SolidColorBrush x:Key="MultiTrackTrackBgBrush" Color="#1c1c26" />
            <SolidColorBrush x:Key="MultiTrackTrackBorderBrush" Color="#33333f" />
        </ResourceDictionary>


        <ResourceDictionary x:Key="Light">
            <!--【主题颜色】-->
            <Color x:Key="ThemeColor">#2b20d9</Color>

            <!--鼠标经过背景颜色-->
            <Color x:Key="HoverBackgroundColor">#eaeaea</Color>

            <!--【通用笔刷】-->
            <!--主题颜色笔刷-->
            <SolidColorBrush x:Key="ThemeBrush" Color="{StaticResource ThemeColor}" />
            <!---鼠标经过背景颜色-->
            <SolidColorBrush x:Key="HoverBackgroundBrush" Color="{StaticResource HoverBackgroundColor}" />
            <!--标准背景颜色-->
            <SolidColorBrush x:Key="StandardBackgroundBrush" Color="#ffffff" />
            <SolidColorBrush x:Key="StandardBackgroundBrush2" Color="#ffffff" />

            <!--【窗口】-->

            <!--窗口边框颜色-->
            <SolidColorBrush x:Key="WindowBorderBrush" Color="#ccc" />

            <SolidColorBrush x:Key="StandardTextBrush" Color="#000" />
            <SolidColorBrush x:Key="SubTextBrush" Color="#7e7e7e" />

            <SolidColorBrush x:Key="Background" Color="#f3f3f3" />
            <!--窗口背景颜色-->
            <!--<SolidColorBrush x:Key="WindowBackground" Color="#f3f3f3" />-->
            <LinearGradientBrush x:Key="WindowBackground" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#ededf0" Offset="0" />
                <GradientStop Color="#ffffff" Offset="0.4" />
                <GradientStop Color="#f5f5f7" Offset="0.8" />
                <GradientStop Color="{DynamicResource ThemeColor}" Offset="1.6" />
            </LinearGradientBrush>

            <SolidColorBrush x:Key="WindowContentBackground" Color="#f9f9f9" />
            <SolidColorBrush x:Key="WindowContentBorder" Color="#ccc" />
            <SolidColorBrush x:Key="CardBorder" Color="#ccc" />
            <SolidColorBrush x:Key="WindowGlassHighlightBrush" Color="#ffffff" Opacity="0.35" />
            <SolidColorBrush x:Key="WindowBackgroundSolid" Color="#ededf0" />

            <!--导航栏-->
            <Color x:Key="NavSelectedColor">#ffffff</Color>
            <SolidColorBrush x:Key="NavSelectedBrush" Color="{StaticResource NavSelectedColor}" />

            <Color x:Key="NavUnselectedTextColor">#5c5c5c</Color>
            <SolidColorBrush x:Key="NavUnselectedTextBrush" Color="{StaticResource NavUnselectedTextColor}" />

            <!--导航栏毛玻璃效果-->
            <SolidColorBrush x:Key="NavGlassBackgroundBrush" Color="#ffffff" Opacity="0.38" />
            <SolidColorBrush x:Key="NavGlassBorderBrush" Color="#ffffff" Opacity="0.45" />
            <SolidColorBrush x:Key="NavSelectedGlassBrush" Color="{DynamicResource ThemeColor}" Opacity="0.14" />
            <SolidColorBrush x:Key="NavSelectedGlassBorderBrush" Color="{DynamicResource ThemeColor}" Opacity="0.18" />
            <SolidColorBrush x:Key="NavHoverGlassBrush" Color="#000000" Opacity="0.03" />

            <!--设置面板-->
            <Color x:Key="SettingPanelBgColor">#ffffff</Color>
            <SolidColorBrush x:Key="SettingPanelBgBrush" Color="{StaticResource SettingPanelBgColor}" />
            <Color x:Key="SettingPanelBorderColor">#ededed</Color>
            <SolidColorBrush x:Key="SettingPanelBorderBrush" Color="{StaticResource SettingPanelBorderColor}" />
            <Color x:Key="SettingPanelSpliteLineColor">#ededed</Color>
            <SolidColorBrush x:Key="SettingPanelSpliteLineBrush" Color="{StaticResource SettingPanelSpliteLineColor}" />

            <!--白色背景文字颜色-->
            <Color x:Key="WhiteBgTextColor">#5c5c5c</Color>
            <SolidColorBrush x:Key="WhiteBgTextBrush" Color="{StaticResource WhiteBgTextColor}" />

            <!--默认基础文字颜色-->
            <Color x:Key="DefaultTextColor">#5c5c5c</Color>
            <SolidColorBrush x:Key="DefaultTextBrush" Color="{StaticResource DefaultTextColor}" />

            <!--列表-->
            <Color x:Key="ListItemIconBgColor">#f3f3f3</Color>
            <SolidColorBrush x:Key="ListItemIconBgBrush" Color="{StaticResource ListItemIconBgColor}" />

            <Color x:Key="BaseListItemBgColor">#f3f3f3</Color>
            <SolidColorBrush x:Key="BaseListItemBgBrush" Color="{StaticResource BaseListItemBgColor}" />
            <Color x:Key="BaseListItemHoverBgColor">#eaeaea</Color>

            <!--日期选择控件-->
            <Color x:Key="DatePickerItemBgColor">#F9F9F9</Color>
            <SolidColorBrush x:Key="DatePickerItemBgBrush" Color="{StaticResource DatePickerItemBgColor}" />

            <!--月热力图控件-->
            <Color x:Key="ChartMonthGridItemBgColor">#fbfafa</Color>
            <SolidColorBrush x:Key="ChartMonthGridItemBgBrush" Color="{StaticResource ChartMonthGridItemBgColor}" />

            <!--弹出层边框-->
            <Color x:Key="PopupBorderColor">#eaeaea</Color>
            <SolidColorBrush x:Key="PopupBorderBrush" Color="{StaticResource PopupBorderColor}" />
            <Color x:Key="PopupBackgroundColor">#ffffff</Color>
            <SolidColorBrush x:Key="PopupBackgroundBrush" Color="{StaticResource PopupBackgroundColor}" />

            <!--标题栏按钮-->
            <Color x:Key="TitleBarBtnColor">#000000</Color>
            <SolidColorBrush x:Key="TitleBarBtnBrush" Color="{StaticResource TitleBarBtnColor}" />

            <!--分割线颜色-->
            <Color x:Key="SeparatorColor">#FFECECEC</Color>
            <SolidColorBrush x:Key="SeparatorBrush" Color="{StaticResource SeparatorColor}" />

            <!--上下文菜单-->
            <Color x:Key="ContextBorderColor">#c4c4c4</Color>
            <SolidColorBrush x:Key="ContextBorderBrush" Color="{StaticResource ContextBorderColor}" />

            <!--图表边框-->
            <Color x:Key="ChartColBorderColor">#eeeef2</Color>
            <SolidColorBrush x:Key="ChartColBorderBrush" Color="{StaticResource ChartColBorderColor}" />

            <!--分类页面-->
            <Color x:Key="CategoryAppNumBgColor">#F9F9F9</Color>
            <SolidColorBrush x:Key="CategoryAppNumBgBrush" Color="{StaticResource CategoryAppNumBgColor}" />

            <!--分类页卡片玻璃效果-->
            <SolidColorBrush x:Key="CategoryCardGlassBgBrush" Color="#ffffff" Opacity="0.50" />
            <SolidColorBrush x:Key="CategoryCardGlassBorderBrush" Color="#ffffff" Opacity="0.55" />
            <SolidColorBrush x:Key="CategoryCardHoverGlassBrush" Color="#000000" Opacity="0.04" />
            <SolidColorBrush x:Key="CategoryCardHoverBorderBrush" Color="{DynamicResource ThemeColor}" Opacity="0.25" />

            <!--Chart 卡片玻璃效果-->
            <SolidColorBrush x:Key="ChartCardGlassBgBrush" Color="#f7f7fa" />
            <SolidColorBrush x:Key="ChartCardGlassBorderBrush" Color="#c8c8d8" Opacity="0.80" />
            <SolidColorBrush x:Key="ChartCardHoverGlassBgBrush" Color="#efeff5" />
            <SolidColorBrush x:Key="ChartCardHoverBorderBrush" Color="{DynamicResource ThemeColor}" Opacity="0.50" />

            <!--Chart 卡片药丸标签-->
            <SolidColorBrush x:Key="ChartCardPillBgBrush" Color="{DynamicResource ThemeColor}" Opacity="0.72" />
            <SolidColorBrush x:Key="ChartCardPillTextBrush" Color="#ffffff" />

            <!--输入框-->
            <Color x:Key="InputBoxBgColor">#F3F3F4</Color>
            <SolidColorBrush x:Key="InputBoxBgBrush" Color="{StaticResource InputBoxBgColor}" />
            <Color x:Key="InputBoxHoverColor">#EAEAEA</Color>
            <SolidColorBrush x:Key="InputBoxHoverBrush" Color="{StaticResource InputBoxHoverColor}" />
            <Color x:Key="InputBoxFocusedBgColor">#FFFFFF</Color>
            <SolidColorBrush x:Key="InputBoxFocusedBgBrush" Color="{StaticResource InputBoxFocusedBgColor}" />

            <!--expander-->
            <Color x:Key="ExpanderBgColor">#ffffff</Color>
            <SolidColorBrush x:Key="ExpanderBgBrush" Color="{StaticResource ExpanderBgColor}" />
            <Color x:Key="ExpanderContentBgColor">#f7f7f7</Color>
            <SolidColorBrush x:Key="ExpanderContentBgBrush" Color="{StaticResource ExpanderContentBgColor}" />

            <!--占位框-->
            <Color x:Key="PlaceholderRectBgColor">#e0e0e0</Color>
            <SolidColorBrush x:Key="PlaceholderRectBgBrush" Color="{StaticResource PlaceholderRectBgColor}" />
            <Color x:Key="PlaceholderRectBgFlashColor">#ffffff</Color>
            <SolidColorBrush x:Key="PlaceholderRectBgFlashBrush" Color="{StaticResource PlaceholderRectBgFlashColor}" />


            <!--禁用颜色-->
            <Color x:Key="DisabledTextColor">#ccc</Color>
            <SolidColorBrush x:Key="DisabledTextBrush" Color="{StaticResource DisabledTextColor}" />

            <Color x:Key="ScrollBarColor">#8A8A8A</Color>
            <SolidColorBrush x:Key="ScrollBarBrush" Color="{StaticResource ScrollBarColor}" />

            <!--列表图表-->
            <Color x:Key="ChartTypeListProgressBarColor">#7F777777</Color>
            <SolidColorBrush x:Key="ChartTypeListProgressBarBrush"
                             Color="{StaticResource ChartTypeListProgressBarColor}" />

            <!--危险警告颜色-->
            <Color x:Key="DangerColor">#f51837</Color>
            <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />

            <!--提示颜色-->
            <Color x:Key="WarningColor">#FFC408</Color>
            <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
            
            <SolidColorBrush x:Key="GrayDark" Color="#e8e8ea" Opacity="0.65" />
            
            <Color x:Key="TabOptionTextColor">#4b5563</Color>
            <Color x:Key="TabOptionTextCheckedColor">#111827</Color>
            <SolidColorBrush x:Key="TabOptionHoverBrush" Color="#e2e2e6" />
            <SolidColorBrush x:Key="TabOptionSelectedBrush" Color="{DynamicResource ThemeColor}" Opacity="0.30" />
            <SolidColorBrush x:Key="TabOptionSelectedBorderBrush" Color="{DynamicResource ThemeColor}" Opacity="0.45" />

            <!-- 时间轴 -->
            <SolidColorBrush x:Key="TimelineBgBrush" Color="#ffffff" />
            <SolidColorBrush x:Key="TimelineBorderBrush" Color="#e0e0e0" />
            <SolidColorBrush x:Key="TimelineHeaderBgBrush" Color="#ffffff" Opacity="0.7" />
            <SolidColorBrush x:Key="TimelineInactiveBrush" Color="#e0e0e0" />
            <SolidColorBrush x:Key="TimelineTickMajorBrush" Color="#d0d0d0" />
            <SolidColorBrush x:Key="TimelineTickHalfBrush" Color="#e0e0e0" />
            <SolidColorBrush x:Key="TimelineTickQuarterBrush" Color="#f0f0f0" />
            <SolidColorBrush x:Key="TimelineTickTextBrush" Color="#7e7e7e" />
            <SolidColorBrush x:Key="TimelineTimeLabelBrush" Color="#7e7e7e" Opacity="0.85" />
            <SolidColorBrush x:Key="TimelineNowBrush" Color="#2b20d9" />
            <SolidColorBrush x:Key="TimelineSelectBgBrush" Color="#2b20d9" Opacity="0.18" />
            <SolidColorBrush x:Key="TimelineSelectBorderBrush" Color="#2b20d9" Opacity="0.80" />
            <SolidColorBrush x:Key="TimelineTipBgBrush" Color="#f9f9f9" />
            <SolidColorBrush x:Key="TimelineTipBorderBrush" Color="#e0e0e0" />
            <SolidColorBrush x:Key="TimelineTipTextBrush" Color="#000000" />
            <SolidColorBrush x:Key="TimelineTipSubBrush" Color="#7e7e7e" />
            <SolidColorBrush x:Key="TimelineTrackBgBrush" Color="#f0f0f0" />
            <SolidColorBrush x:Key="TimelineTooltipShadowBrush" Color="#000000" Opacity="0.15" />
            <Color x:Key="TimelineIdleColor">#b0b0b0</Color>
            <Color x:Key="TimelineDefaultColor">#888888</Color>
            <SolidColorBrush x:Key="TimelineNowDotOuterBrush" Color="#cccccc" />

            <!-- 时间轴时段背景 -->
            <SolidColorBrush x:Key="TimelinePeriodNightBgBrush" Color="#e0e6f2" />
            <SolidColorBrush x:Key="TimelinePeriodMorningBgBrush" Color="#e0f0e0" />
            <SolidColorBrush x:Key="TimelinePeriodNoonBgBrush" Color="#f0f0f0" />
            <SolidColorBrush x:Key="TimelinePeriodAfternoonBgBrush" Color="#f2e8e0" />
            <SolidColorBrush x:Key="TimelinePeriodEveningBgBrush" Color="#e8e0f2" />

            <!-- 时间轴框选 -->
            <SolidColorBrush x:Key="TimelineSelectionMaskBrush" Color="#000000" Opacity="0.35" />
            <SolidColorBrush x:Key="TimelineSelectionBorderBrush" Color="#2a2a2a" />
            <SolidColorBrush x:Key="TimelineSelectionGlowBrush" Color="#2b20d9" Opacity="0.1" />
            <SolidColorBrush x:Key="TimelineSelectionHandleBrush" Color="#2b20d9" />
            <SolidColorBrush x:Key="TimelineSelectionHandleBorderBrush" Color="#ffffff" />
            <SolidColorBrush x:Key="TimelineSelectionLabelBgBrush" Color="#f9f9f9" />
            <SolidColorBrush x:Key="TimelineSelectionLabelTextBrush" Color="#000000" />

            <!-- 多轨道时间轴 -->
            <SolidColorBrush x:Key="MultiTrackRowBgBrush" Color="#f7f7fa" />
            <SolidColorBrush x:Key="MultiTrackRowBorderBrush" Color="#e4e4ec" />
            <SolidColorBrush x:Key="MultiTrackIconBgBrush" Color="#eeeef4" />
            <SolidColorBrush x:Key="MultiTrackTrackBgBrush" Color="#eaeaef" />
            <SolidColorBrush x:Key="MultiTrackTrackBorderBrush" Color="#dddde5" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>