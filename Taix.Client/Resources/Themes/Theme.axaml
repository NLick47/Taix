<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 圆角 -->
    <CornerRadius x:Key="RadiusSmall">8</CornerRadius>
    <CornerRadius x:Key="RadiusMedium">16</CornerRadius>
    <CornerRadius x:Key="RadiusLarge">16</CornerRadius>
    <CornerRadius x:Key="RadiusXLarge">20</CornerRadius>
    <CornerRadius x:Key="RadiusPill">999</CornerRadius>

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">
            <!--【主题颜色】-->
            <Color x:Key="ThemeColor">#FF8780F7</Color>

            <Color x:Key="Surface0">#0C0C0C</Color>
            <Color x:Key="Surface1">#161618</Color>
            <Color x:Key="Surface2">#1E1E22</Color>
            <Color x:Key="Surface3">#28282E</Color>
            <Color x:Key="Surface4">#383840</Color>

            <Color x:Key="BorderSubtle">#252528</Color>
            <Color x:Key="BorderDefault">#35353A</Color>
            <Color x:Key="BorderStrong">#484850</Color>

            <!--【色阶系统 - 文字】-->
            <Color x:Key="TextPrimary">#F0F0F0</Color>
            <Color x:Key="TextSecondary">#A8A8B0</Color>
            <Color x:Key="TextTertiary">#686870</Color>
            <Color x:Key="TextDisabled">#505058</Color>

            <!--鼠标经过背景颜色-->
            <Color x:Key="HoverBackgroundColor">#4A4A52</Color>

            <!--【通用笔刷】-->
            <!--主题颜色笔刷-->
            <SolidColorBrush x:Key="ThemeBrush" Color="{StaticResource ThemeColor}" />
            <!---鼠标经过背景颜色-->
            <SolidColorBrush x:Key="HoverBackgroundBrush" Color="{StaticResource HoverBackgroundColor}" />
            <!--标准背景颜色-->
            <SolidColorBrush x:Key="StandardBackgroundBrush" Color="{StaticResource Surface4}" />
            <SolidColorBrush x:Key="StandardBackgroundBrush2" Color="{StaticResource Surface4}" />
            <SolidColorBrush x:Key="ButtonBorderBrush" Color="{StaticResource BorderDefault}" />

            <!--【全局搜索浮窗中性色骨架】-->
            <Color x:Key="SearchSurfaceColor">#24232A</Color>
            <Color x:Key="SearchInputColor">#2A2930</Color>
            <Color x:Key="SearchFooterColor">#2A2930</Color>
            <Color x:Key="SearchBorderLightColor">#3A3940</Color>
            <Color x:Key="SearchBorderMediumColor">#4A4950</Color>
            <SolidColorBrush x:Key="SearchSurfaceBrush" Color="{StaticResource SearchSurfaceColor}" />
            <SolidColorBrush x:Key="SearchInputBrush" Color="{StaticResource SearchInputColor}" />
            <SolidColorBrush x:Key="SearchFooterBrush" Color="{StaticResource SearchFooterColor}" />
            <SolidColorBrush x:Key="SearchBorderLightBrush" Color="{StaticResource SearchBorderLightColor}" />

            <!--【窗口】-->
            <!--窗口边框颜色-->
            <SolidColorBrush x:Key="WindowBorderBrush" Color="{StaticResource BorderDefault}" />

            <SolidColorBrush x:Key="StandardTextBrush" Color="{StaticResource TextPrimary}" />
            <SolidColorBrush x:Key="SubTextBrush" Color="{StaticResource TextSecondary}" />

            <SolidColorBrush x:Key="Background" Color="{StaticResource Surface1}" />
            <LinearGradientBrush x:Key="WindowBackgroundModern" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#080814" Offset="0" />
                <GradientStop Color="#1A1A32" Offset="0.5" />
                <GradientStop Color="#2E2E52" Offset="1" />
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="WindowBackgroundClassic" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#050510" Offset="0" />
                <GradientStop Color="#12122A" Offset="0.35" />
                <GradientStop Color="#2A2660" Offset="0.7" />
                <GradientStop Color="#4A3A8A" Offset="1" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="WindowBackgroundOriginal" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#131315" Offset="0" />
                <GradientStop Color="#1a1a1e" Offset="0.4" />
                <GradientStop Color="#18181c" Offset="0.8" />
                <GradientStop Color="{DynamicResource ThemeColor}" Offset="1.3" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="WindowBackground" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#080814" Offset="0" />
                <GradientStop Color="#1A1A32" Offset="0.5" />
                <GradientStop Color="#2E2E52" Offset="1" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="WindowContentBackground" Color="{StaticResource Surface3}" Opacity="0.6" />
            <SolidColorBrush x:Key="WindowContentBorder" Color="{StaticResource BorderSubtle}" />
            <SolidColorBrush x:Key="CardBorder" Color="Transparent" />
            <SolidColorBrush x:Key="WindowGlassHighlightBrush" Color="#ffffff" Opacity="0.08" />
            <SolidColorBrush x:Key="WindowBackgroundSolid" Color="{StaticResource Surface1}" />

            <!--导航栏-->
            <Color x:Key="NavSelectedColor">#2E2E36</Color>
            <SolidColorBrush x:Key="NavSelectedBrush" Color="{StaticResource NavSelectedColor}" />

            <Color x:Key="NavUnselectedTextColor">#B0B0B8</Color>
            <SolidColorBrush x:Key="NavUnselectedTextBrush" Color="{StaticResource NavUnselectedTextColor}" />

            <!--导航栏毛玻璃效果-->
            <SolidColorBrush x:Key="NavGlassBackgroundBrush" Color="{StaticResource Surface1}" Opacity="0.45" />
            <SolidColorBrush x:Key="NavGlassBorderBrush" Color="#ffffff" Opacity="0.10" />
            <SolidColorBrush x:Key="NavBorderBrush" Color="{StaticResource BorderDefault}" />
            <SolidColorBrush x:Key="NavSelectedGlassBrush" Color="{DynamicResource ThemeColor}" Opacity="0.20" />
            <SolidColorBrush x:Key="NavSelectedGlassBorderBrush" Color="{DynamicResource ThemeColor}" Opacity="0.35" />
            <SolidColorBrush x:Key="NavHoverGlassBrush" Color="#ffffff" Opacity="0.08" />

            <!--日期选择器专用背景（深色主题）-->
            <SolidColorBrush x:Key="DatePickerGlassBackgroundBrush" Color="#FFFFFF" Opacity="0.04" />
            <SolidColorBrush x:Key="DatePickerGlassBorderBrush" Color="#FFFFFF" Opacity="0.08" />
            <SolidColorBrush x:Key="DatePickerHoverGlassBrush" Color="#ffffff" Opacity="0.12" />

            <!--设置面板-->
            <Color x:Key="SettingPanelBgColor">#2A2A30</Color>
            <SolidColorBrush x:Key="SettingPanelBgBrush" Color="{StaticResource SettingPanelBgColor}" />
            <SolidColorBrush x:Key="SettingPanelBorderBrush" Color="#FFFFFF" Opacity="0.05" />
            <Color x:Key="SettingPanelSpliteLineColor">#45454D</Color>
            <SolidColorBrush x:Key="SettingPanelSpliteLineBrush" Color="{StaticResource SettingPanelSpliteLineColor}" />

            <!--白色背景文字颜色-->
            <Color x:Key="WhiteBgTextColor">#C8C8D0</Color>
            <SolidColorBrush x:Key="WhiteBgTextBrush" Color="{StaticResource WhiteBgTextColor}" />

            <!--默认基础文字颜色-->
            <Color x:Key="DefaultTextColor">#E8E8EC</Color>
            <SolidColorBrush x:Key="DefaultTextBrush" Color="{StaticResource DefaultTextColor}" />

            <!--列表-->
            <Color x:Key="ListItemIconBgColor">#323238</Color>
            <SolidColorBrush x:Key="ListItemIconBgBrush" Color="{StaticResource ListItemIconBgColor}" />

            <Color x:Key="BaseListItemBgColor">#323238</Color>
            <SolidColorBrush x:Key="BaseListItemBgBrush" Color="{StaticResource BaseListItemBgColor}" />
            <Color x:Key="BaseListItemHoverBgColor">#424248</Color>

            <!--列表项交互-->
            <SolidColorBrush x:Key="ListItemHoverBrush" Color="{DynamicResource ThemeColor}" Opacity="0.10" />
            <SolidColorBrush x:Key="ListItemPressedBrush" Color="{DynamicResource ThemeColor}" Opacity="0.22" />
            <SolidColorBrush x:Key="ListItemSelectedBrush" Color="{DynamicResource ThemeColor}" Opacity="0.16" />
            <SolidColorBrush x:Key="ListItemSelectedHoverBrush" Color="{DynamicResource ThemeColor}" Opacity="0.24" />
            <SolidColorBrush x:Key="ListItemAccentBrush" Color="{DynamicResource ThemeColor}" Opacity="0.85" />

            <!--全局搜索徽标（暗色：背景半透明，前景接近主题色但更亮以保证对比度）-->
            <SolidColorBrush x:Key="ThemeBadgeBgBrush" Color="{DynamicResource ThemeColor}" Opacity="0.22" />
            <SolidColorBrush x:Key="ThemeBadgeFgBrush" Color="{DynamicResource ThemeColor}" />

            <!--日期选择控件-->
            <Color x:Key="DatePickerItemBgColor">#484850</Color>
            <SolidColorBrush x:Key="DatePickerItemBgBrush" Color="{StaticResource DatePickerItemBgColor}" />

            <!--月热力图控件-->
            <Color x:Key="ChartMonthGridItemBgColor">#505058</Color>
            <SolidColorBrush x:Key="ChartMonthGridItemBgBrush" Color="{StaticResource ChartMonthGridItemBgColor}" />

            <!--弹出层边框-->
            <Color x:Key="PopupBorderColor">#3A3A42</Color>
            <SolidColorBrush x:Key="PopupBorderBrush" Color="{StaticResource PopupBorderColor}" />
            <Color x:Key="PopupBackgroundColor">#222228</Color>
            <SolidColorBrush x:Key="PopupBackgroundBrush" Color="{StaticResource PopupBackgroundColor}" />

            <!--标题栏按钮-->
            <Color x:Key="TitleBarBtnColor">#E8E8EC</Color>
            <SolidColorBrush x:Key="TitleBarBtnBrush" Color="{StaticResource TitleBarBtnColor}" />

            <!--分割线颜色-->
            <Color x:Key="SeparatorColor">#404048</Color>
            <SolidColorBrush x:Key="SeparatorBrush" Color="{StaticResource SeparatorColor}" />

            <!--上下文菜单-->
            <Color x:Key="ContextBorderColor">#3A3A42</Color>
            <SolidColorBrush x:Key="ContextBorderBrush" Color="{StaticResource ContextBorderColor}" />

            <!--图表边框-->
            <Color x:Key="ChartColBorderColor">#505058</Color>
            <SolidColorBrush x:Key="ChartColBorderBrush" Color="{StaticResource ChartColBorderColor}" />

            <!--分类页面-->
            <Color x:Key="CategoryAppNumBgColor">#484850</Color>
            <SolidColorBrush x:Key="CategoryAppNumBgBrush" Color="{StaticResource CategoryAppNumBgColor}" />

            <!--分类页卡片玻璃效果-->
            <SolidColorBrush x:Key="CategoryCardGlassBgBrush" Color="#ffffff" Opacity="0.06" />
            <SolidColorBrush x:Key="CategoryCardGlassBorderBrush" Color="#ffffff" Opacity="0.14" />
            <SolidColorBrush x:Key="CategoryCardHoverGlassBrush" Color="#ffffff" Opacity="0.10" />
            <SolidColorBrush x:Key="CategoryCardHoverBorderBrush" Color="{DynamicResource ThemeColor}" Opacity="0.50" />

            <!--Chart 卡片玻璃效果-->
            <SolidColorBrush x:Key="ChartCardGlassBgBrush" Color="#ffffff" Opacity="0.04" />
            <SolidColorBrush x:Key="ChartCardGlassBorderBrush" Color="#ffffff" Opacity="0.10" />
            <SolidColorBrush x:Key="ChartCardHoverGlassBgBrush" Color="#ffffff" Opacity="0.07" />
            <SolidColorBrush x:Key="ChartCardHoverBorderBrush" Color="{DynamicResource ThemeColor}" Opacity="0.45" />

            <!--Chart 卡片药丸标签-->
            <SolidColorBrush x:Key="ChartCardPillBgBrush" Color="{DynamicResource ThemeColor}" Opacity="0.20" />
            <SolidColorBrush x:Key="ChartCardPillTextBrush" Color="#ffffff" />

            <!--输入框-->
            <Color x:Key="InputBoxBgColor">#323238</Color>
            <SolidColorBrush x:Key="InputBoxBgBrush" Color="{StaticResource InputBoxBgColor}" />
            <Color x:Key="InputBoxHoverColor">#424248</Color>
            <SolidColorBrush x:Key="InputBoxHoverBrush" Color="{StaticResource InputBoxHoverColor}" />
            <Color x:Key="InputBoxFocusedBgColor">#3A3A42</Color>
            <SolidColorBrush x:Key="InputBoxFocusedBgBrush" Color="{StaticResource InputBoxFocusedBgColor}" />

            <!--expander-->
            <Color x:Key="ExpanderBgColor">#2A2A30</Color>
            <SolidColorBrush x:Key="ExpanderBgBrush" Color="{StaticResource ExpanderBgColor}" />
            <Color x:Key="ExpanderContentBgColor">#242428</Color>
            <SolidColorBrush x:Key="ExpanderContentBgBrush" Color="{StaticResource ExpanderContentBgColor}" />

            <!--占位框-->
            <Color x:Key="PlaceholderRectBgColor">#2E2E34</Color>
            <SolidColorBrush x:Key="PlaceholderRectBgBrush" Color="{StaticResource PlaceholderRectBgColor}" />
            <Color x:Key="PlaceholderRectBgFlashColor">#424248</Color>
            <SolidColorBrush x:Key="PlaceholderRectBgFlashBrush" Color="{StaticResource PlaceholderRectBgFlashColor}" />

            <Color x:Key="DisabledTextColor">#585860</Color>
            <SolidColorBrush x:Key="DisabledTextBrush" Color="{StaticResource DisabledTextColor}" />

            <!--滚动条-->
            <Color x:Key="ScrollBarColor">#787880</Color>
            <SolidColorBrush x:Key="ScrollBarBrush" Color="{StaticResource ScrollBarColor}" />

            <!--列表图表-->
            <Color x:Key="ChartTypeListProgressBarColor">#505058</Color>
            <SolidColorBrush x:Key="ChartTypeListProgressBarBrush" Color="{StaticResource ChartTypeListProgressBarColor}" />

            <!--危险颜色-->
            <Color x:Key="DangerColor">#f51837</Color>
            <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />

            <!--成功颜色-->
            <Color x:Key="SuccessColor">#24bf5f</Color>
            <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />

            <!--白底文字（用于彩色徽章上的白色文字）-->
            <SolidColorBrush x:Key="OnAccentBrush" Color="#ffffff" />

            <!--提示颜色-->
            <Color x:Key="WarningColor">#FFC408</Color>
            <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />

            <SolidColorBrush x:Key="GrayDark" Color="#1C1C20" Opacity="0.60" />

            <!-- TabSwitch 容器 -->
            <SolidColorBrush x:Key="TabSwitchBgBrush" Color="#FFFFFF" Opacity="0.04" />
            <SolidColorBrush x:Key="TabSwitchBorderBrush" Color="#FFFFFF" Opacity="0.08" />

            <!-- 选项文字 -->
            <Color x:Key="TabOptionTextColor">#B8B8C0</Color>
            <Color x:Key="TabOptionTextCheckedColor">#FFFFFF</Color>

            <!-- 选中滑块 -->
            <SolidColorBrush x:Key="TabOptionSelectedBrush" Color="#FFFFFF" Opacity="0.10" />
            <SolidColorBrush x:Key="TabSliderBorderBrush" Color="#FFFFFF" Opacity="0.12" />
            <SolidColorBrush x:Key="TabOptionSelectedBorderBrush" Color="#FFFFFF" Opacity="0.15" />

            <!-- Option 选项边框 -->
            <SolidColorBrush x:Key="OptionUncheckedBorderBrush" Color="#FFFFFF" Opacity="0.15" />
            <SolidColorBrush x:Key="OptionCheckedBorderBrush" Color="{DynamicResource ThemeColor}" Opacity="0.50" />
            <SolidColorBrush x:Key="OptionCheckedBackgroundBrush" Color="{DynamicResource ThemeColor}" Opacity="0.20" />

            <!-- 时间轴 -->
            <SolidColorBrush x:Key="TimelineBgBrush" Color="#0E0E12" />
            <SolidColorBrush x:Key="TimelineBorderBrush" Color="#222228" />
            <SolidColorBrush x:Key="TimelineHeaderBgBrush" Color="#16161C" Opacity="0.75" />
            <SolidColorBrush x:Key="TimelineInactiveBrush" Color="#35353D" />
            <SolidColorBrush x:Key="TimelineTickMajorBrush" Color="#35353D" />
            <SolidColorBrush x:Key="TimelineTickHalfBrush" Color="#28282E" />
            <SolidColorBrush x:Key="TimelineTickQuarterBrush" Color="#1E1E24" />
            <SolidColorBrush x:Key="TimelineTickTextBrush" Color="#787880" />
            <SolidColorBrush x:Key="TimelineTimeLabelBrush" Color="#787880" Opacity="0.85" />
            <SolidColorBrush x:Key="TimelineNowBrush" Color="#58a6ff" />
            <SolidColorBrush x:Key="TimelineSelectBgBrush" Color="#58a6ff" Opacity="0.20" />
            <SolidColorBrush x:Key="TimelineSelectBorderBrush" Color="#58a6ff" Opacity="0.80" />
            <SolidColorBrush x:Key="TimelineTipBgBrush" Color="#1A1A20" />
            <SolidColorBrush x:Key="TimelineTipBorderBrush" Color="#35353D" />
            <SolidColorBrush x:Key="TimelineTipTextBrush" Color="#F0F0F0" />
            <SolidColorBrush x:Key="TimelineTipSubBrush" Color="#787880" />
            <SolidColorBrush x:Key="TimelineTrackBgBrush" Color="#222228" />
            <SolidColorBrush x:Key="TimelineTooltipShadowBrush" Color="#000000" Opacity="0.45" />
            <Color x:Key="TimelineIdleColor">#484850</Color>
            <Color x:Key="TimelineDefaultColor">#707078</Color>
            <SolidColorBrush x:Key="TimelineNowDotOuterBrush" Color="#E8E8EC" />

            <!-- 时间轴时段背景 -->
            <SolidColorBrush x:Key="TimelinePeriodNightBgBrush" Color="#1E2430" />
            <SolidColorBrush x:Key="TimelinePeriodMorningBgBrush" Color="#1E3024" />
            <SolidColorBrush x:Key="TimelinePeriodNoonBgBrush" Color="#26262C" />
            <SolidColorBrush x:Key="TimelinePeriodAfternoonBgBrush" Color="#30261E" />
            <SolidColorBrush x:Key="TimelinePeriodEveningBgBrush" Color="#2A2630" />

            <!-- 时间轴框选 -->
            <SolidColorBrush x:Key="TimelineSelectionMaskBrush" Color="#000000" Opacity="0.22" />
            <SolidColorBrush x:Key="TimelineSelectionBorderBrush" Color="#748ffc" />
            <SolidColorBrush x:Key="TimelineSelectionGlowBrush" Color="#748ffc" Opacity="0.12" />
            <SolidColorBrush x:Key="TimelineSelectionHandleBrush" Color="#748ffc" />
            <SolidColorBrush x:Key="TimelineSelectionHandleBorderBrush" Color="#B0B8FF" />
            <SolidColorBrush x:Key="TimelineSelectionLabelBgBrush" Color="#1A2238" />
            <SolidColorBrush x:Key="TimelineSelectionLabelTextBrush" Color="#B0B8FF" />

            <!-- 多轨道时间轴 -->
            <SolidColorBrush x:Key="MultiTrackRowBgBrush" Color="#26262C" />
            <SolidColorBrush x:Key="MultiTrackRowBorderBrush" Color="#383840" />
            <SolidColorBrush x:Key="MultiTrackIconBgBrush" Color="#303038" />
            <SolidColorBrush x:Key="MultiTrackTrackBgBrush" Color="#1A1A20" />
            <SolidColorBrush x:Key="MultiTrackTrackBorderBrush" Color="#303038" />

            <!-- 颜色模式切换 -->
            <SolidColorBrush x:Key="ColorModeToggleBgBrush" Color="#1A1A20" />
            <SolidColorBrush x:Key="ColorModeToggleBorderBrush" Color="#2E2E36" />
            <SolidColorBrush x:Key="ColorModeToggleCheckedBgBrush" Color="#3A3A44" />
            <SolidColorBrush x:Key="ColorModeToggleCheckedBorderBrush" Color="#50505A" />
            <SolidColorBrush x:Key="ColorModeToggleCheckedTextBrush" Color="#E8E8F0" />
            <SolidColorBrush x:Key="ColorModeToggleUncheckedTextBrush" Color="#787884" />
            <SolidColorBrush x:Key="ColorModeToggleHoverTextBrush" Color="#C0C0CC" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="Light">
            <!--【主题颜色】-->
            <Color x:Key="ThemeColor">#2b20d9</Color>

            <!--鼠标经过背景颜色-->
            <Color x:Key="HoverBackgroundColor">#eaeaea</Color>

            <!--【通用笔刷】-->
            <!--主题颜色笔刷-->
            <SolidColorBrush x:Key="ThemeBrush" Color="{StaticResource ThemeColor}" />
            <!---鼠标经过背景颜色-->
            <SolidColorBrush x:Key="HoverBackgroundBrush" Color="{StaticResource HoverBackgroundColor}" />
            <!--标准背景颜色-->
            <SolidColorBrush x:Key="StandardBackgroundBrush" Color="#ffffff" />
            <SolidColorBrush x:Key="StandardBackgroundBrush2" Color="#ffffff" />
            <SolidColorBrush x:Key="ButtonBorderBrush" Color="#d0d0d0" />

            <!--【全局搜索浮窗中性色骨架】-->
            <Color x:Key="SearchSurfaceColor">#FFFFFF</Color>
            <Color x:Key="SearchInputColor">#F8F7FA</Color>
            <Color x:Key="SearchFooterColor">#F5F4F7</Color>
            <Color x:Key="SearchBorderLightColor">#EAE8EE</Color>
            <Color x:Key="SearchBorderMediumColor">#DDDBE2</Color>
            <SolidColorBrush x:Key="SearchSurfaceBrush" Color="{StaticResource SearchSurfaceColor}" />
            <SolidColorBrush x:Key="SearchInputBrush" Color="{StaticResource SearchInputColor}" />
            <SolidColorBrush x:Key="SearchFooterBrush" Color="{StaticResource SearchFooterColor}" />
            <SolidColorBrush x:Key="SearchBorderLightBrush" Color="{StaticResource SearchBorderLightColor}" />

            <!--【窗口】-->

            <!--窗口边框颜色-->
            <SolidColorBrush x:Key="WindowBorderBrush" Color="#ccc" />

            <SolidColorBrush x:Key="StandardTextBrush" Color="#000" />
            <SolidColorBrush x:Key="SubTextBrush" Color="#7e7e7e" />

            <SolidColorBrush x:Key="Background" Color="#f3f3f3" />
            <!--窗口背景 - 现代方案：干净明亮，灰白渐变，无主题色介入-->
            <LinearGradientBrush x:Key="WindowBackgroundModern" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#C8C8D8" Offset="0" />
                <GradientStop Color="#E8E8F0" Offset="0.5" />
                <GradientStop Color="#FFFFFF" Offset="1" />
            </LinearGradientBrush>
            <!--窗口背景 - 经典方案：梦幻紫蓝渐变，无主题色介入-->
            <LinearGradientBrush x:Key="WindowBackgroundClassic" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#E0E0EC" Offset="0" />
                <GradientStop Color="#FAFAFC" Offset="0.35" />
                <GradientStop Color="#D0C8F8" Offset="0.7" />
                <GradientStop Color="#B8A8E8" Offset="1" />
            </LinearGradientBrush>
            <!--窗口背景 - 原始方案：柔和渐变，主题色轻微晕染-->
            <LinearGradientBrush x:Key="WindowBackgroundOriginal" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#e0e0eb" Offset="0" />
                <GradientStop Color="#ffffff" Offset="0.4" />
                <GradientStop Color="#eaeaf2" Offset="0.75" />
                <GradientStop Color="{DynamicResource ThemeColor}" Offset="1.0" />
            </LinearGradientBrush>
            <!--默认使用现代方案-->
            <LinearGradientBrush x:Key="WindowBackground" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#C8C8D8" Offset="0" />
                <GradientStop Color="#E8E8F0" Offset="0.5" />
                <GradientStop Color="#FFFFFF" Offset="1" />
            </LinearGradientBrush>

            <SolidColorBrush x:Key="WindowContentBackground" Color="#f9f9f9" />
            <SolidColorBrush x:Key="WindowContentBorder" Color="#ccc" />
            <SolidColorBrush x:Key="CardBorder" Color="#ccc" />
            <SolidColorBrush x:Key="WindowGlassHighlightBrush" Color="#ffffff" Opacity="0.35" />
            <SolidColorBrush x:Key="WindowBackgroundSolid" Color="#ededf0" />

            <!--导航栏-->
            <Color x:Key="NavSelectedColor">#ffffff</Color>
            <SolidColorBrush x:Key="NavSelectedBrush" Color="{StaticResource NavSelectedColor}" />

            <Color x:Key="NavUnselectedTextColor">#5c5c5c</Color>
            <SolidColorBrush x:Key="NavUnselectedTextBrush" Color="{StaticResource NavUnselectedTextColor}" />

            <!--导航栏毛玻璃效果-->
            <SolidColorBrush x:Key="NavGlassBackgroundBrush" Color="#ffffff" Opacity="0.38" />
            <SolidColorBrush x:Key="NavGlassBorderBrush" Color="#ffffff" Opacity="0.45" />
            <SolidColorBrush x:Key="NavBorderBrush" Color="#c0c0c0" />
            <SolidColorBrush x:Key="NavSelectedGlassBrush" Color="{DynamicResource ThemeColor}" Opacity="0.14" />
            <SolidColorBrush x:Key="NavSelectedGlassBorderBrush" Color="{DynamicResource ThemeColor}" Opacity="0.18" />
            <SolidColorBrush x:Key="NavHoverGlassBrush" Color="#000000" Opacity="0.03" />

            <!--日期选择器专用背景（浅色主题优化）-->
            <SolidColorBrush x:Key="DatePickerGlassBackgroundBrush" Color="#f5f5f5" />
            <SolidColorBrush x:Key="DatePickerGlassBorderBrush" Color="#e0e0e0" />
            <SolidColorBrush x:Key="DatePickerHoverGlassBrush" Color="#000000" Opacity="0.06" />

            <!--设置面板-->
            <Color x:Key="SettingPanelBgColor">#ffffff</Color>
            <SolidColorBrush x:Key="SettingPanelBgBrush" Color="{StaticResource SettingPanelBgColor}" />
            <SolidColorBrush x:Key="SettingPanelBorderBrush" Color="#000000" Opacity="0.06" />
            <Color x:Key="SettingPanelSpliteLineColor">#ededed</Color>
            <SolidColorBrush x:Key="SettingPanelSpliteLineBrush" Color="{StaticResource SettingPanelSpliteLineColor}" />

            <!--白色背景文字颜色-->
            <Color x:Key="WhiteBgTextColor">#5c5c5c</Color>
            <SolidColorBrush x:Key="WhiteBgTextBrush" Color="{StaticResource WhiteBgTextColor}" />

            <!--默认基础文字颜色-->
            <Color x:Key="DefaultTextColor">#5c5c5c</Color>
            <SolidColorBrush x:Key="DefaultTextBrush" Color="{StaticResource DefaultTextColor}" />

            <!--列表-->
            <Color x:Key="ListItemIconBgColor">#f3f3f3</Color>
            <SolidColorBrush x:Key="ListItemIconBgBrush" Color="{StaticResource ListItemIconBgColor}" />

            <Color x:Key="BaseListItemBgColor">#f3f3f3</Color>
            <SolidColorBrush x:Key="BaseListItemBgBrush" Color="{StaticResource BaseListItemBgColor}" />
            <Color x:Key="BaseListItemHoverBgColor">#eaeaea</Color>

            <!--列表项交互-->
            <SolidColorBrush x:Key="ListItemHoverBrush" Color="{DynamicResource ThemeColor}" Opacity="0.06" />
            <SolidColorBrush x:Key="ListItemPressedBrush" Color="{DynamicResource ThemeColor}" Opacity="0.16" />
            <SolidColorBrush x:Key="ListItemSelectedBrush" Color="{DynamicResource ThemeColor}" Opacity="0.10" />
            <SolidColorBrush x:Key="ListItemSelectedHoverBrush" Color="{DynamicResource ThemeColor}" Opacity="0.16" />
            <SolidColorBrush x:Key="ListItemAccentBrush" Color="{DynamicResource ThemeColor}" Opacity="0.90" />

            <!--全局搜索徽标（浅色：更浅背景，文字饱和便于阅读）-->
            <SolidColorBrush x:Key="ThemeBadgeBgBrush" Color="{DynamicResource ThemeColor}" Opacity="0.14" />
            <SolidColorBrush x:Key="ThemeBadgeFgBrush" Color="{DynamicResource ThemeColor}" />

            <!--日期选择控件-->
            <Color x:Key="DatePickerItemBgColor">#F9F9F9</Color>
            <SolidColorBrush x:Key="DatePickerItemBgBrush" Color="{StaticResource DatePickerItemBgColor}" />

            <!--月热力图控件-->
            <Color x:Key="ChartMonthGridItemBgColor">#fbfafa</Color>
            <SolidColorBrush x:Key="ChartMonthGridItemBgBrush" Color="{StaticResource ChartMonthGridItemBgColor}" />

            <!--弹出层边框-->
            <Color x:Key="PopupBorderColor">#eaeaea</Color>
            <SolidColorBrush x:Key="PopupBorderBrush" Color="{StaticResource PopupBorderColor}" />
            <Color x:Key="PopupBackgroundColor">#ffffff</Color>
            <SolidColorBrush x:Key="PopupBackgroundBrush" Color="{StaticResource PopupBackgroundColor}" />

            <!--标题栏按钮-->
            <Color x:Key="TitleBarBtnColor">#000000</Color>
            <SolidColorBrush x:Key="TitleBarBtnBrush" Color="{StaticResource TitleBarBtnColor}" />

            <!--分割线颜色-->
            <Color x:Key="SeparatorColor">#FFECECEC</Color>
            <SolidColorBrush x:Key="SeparatorBrush" Color="{StaticResource SeparatorColor}" />

            <!--上下文菜单-->
            <Color x:Key="ContextBorderColor">#c4c4c4</Color>
            <SolidColorBrush x:Key="ContextBorderBrush" Color="{StaticResource ContextBorderColor}" />

            <!--图表边框-->
            <Color x:Key="ChartColBorderColor">#eeeef2</Color>
            <SolidColorBrush x:Key="ChartColBorderBrush" Color="{StaticResource ChartColBorderColor}" />

            <!--分类页面-->
            <Color x:Key="CategoryAppNumBgColor">#F9F9F9</Color>
            <SolidColorBrush x:Key="CategoryAppNumBgBrush" Color="{StaticResource CategoryAppNumBgColor}" />

            <!--分类页卡片玻璃效果-->
            <SolidColorBrush x:Key="CategoryCardGlassBgBrush" Color="#ffffff" Opacity="0.50" />
            <SolidColorBrush x:Key="CategoryCardGlassBorderBrush" Color="#ffffff" Opacity="0.55" />
            <SolidColorBrush x:Key="CategoryCardHoverGlassBrush" Color="#000000" Opacity="0.04" />
            <SolidColorBrush x:Key="CategoryCardHoverBorderBrush" Color="{DynamicResource ThemeColor}" Opacity="0.25" />

            <!--Chart 卡片玻璃效果-->
            <SolidColorBrush x:Key="ChartCardGlassBgBrush" Color="#f7f7fa" />
            <SolidColorBrush x:Key="ChartCardGlassBorderBrush" Color="#c8c8d8" Opacity="0.80" />
            <SolidColorBrush x:Key="ChartCardHoverGlassBgBrush" Color="#efeff5" />
            <SolidColorBrush x:Key="ChartCardHoverBorderBrush" Color="{DynamicResource ThemeColor}" Opacity="0.50" />

            <!--Chart 卡片药丸标签-->
            <SolidColorBrush x:Key="ChartCardPillBgBrush" Color="{DynamicResource ThemeColor}" Opacity="0.72" />
            <SolidColorBrush x:Key="ChartCardPillTextBrush" Color="#ffffff" />

            <!--输入框-->
            <Color x:Key="InputBoxBgColor">#F3F3F4</Color>
            <SolidColorBrush x:Key="InputBoxBgBrush" Color="{StaticResource InputBoxBgColor}" />
            <Color x:Key="InputBoxHoverColor">#EAEAEA</Color>
            <SolidColorBrush x:Key="InputBoxHoverBrush" Color="{StaticResource InputBoxHoverColor}" />
            <Color x:Key="InputBoxFocusedBgColor">#FFFFFF</Color>
            <SolidColorBrush x:Key="InputBoxFocusedBgBrush" Color="{StaticResource InputBoxFocusedBgColor}" />

            <!--expander-->
            <Color x:Key="ExpanderBgColor">#ffffff</Color>
            <SolidColorBrush x:Key="ExpanderBgBrush" Color="{StaticResource ExpanderBgColor}" />
            <Color x:Key="ExpanderContentBgColor">#f7f7f7</Color>
            <SolidColorBrush x:Key="ExpanderContentBgBrush" Color="{StaticResource ExpanderContentBgColor}" />

            <!--占位框-->
            <Color x:Key="PlaceholderRectBgColor">#e0e0e0</Color>
            <SolidColorBrush x:Key="PlaceholderRectBgBrush" Color="{StaticResource PlaceholderRectBgColor}" />
            <Color x:Key="PlaceholderRectBgFlashColor">#ffffff</Color>
            <SolidColorBrush x:Key="PlaceholderRectBgFlashBrush" Color="{StaticResource PlaceholderRectBgFlashColor}" />


            <!--禁用颜色-->
            <Color x:Key="DisabledTextColor">#ccc</Color>
            <SolidColorBrush x:Key="DisabledTextBrush" Color="{StaticResource DisabledTextColor}" />

            <Color x:Key="ScrollBarColor">#8A8A8A</Color>
            <SolidColorBrush x:Key="ScrollBarBrush" Color="{StaticResource ScrollBarColor}" />

            <!--列表图表-->
            <Color x:Key="ChartTypeListProgressBarColor">#7F777777</Color>
            <SolidColorBrush x:Key="ChartTypeListProgressBarBrush"
                             Color="{StaticResource ChartTypeListProgressBarColor}" />

            <!--危险警告颜色-->
            <Color x:Key="DangerColor">#f51837</Color>
            <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />

            <!--成功颜色-->
            <Color x:Key="SuccessColor">#24bf5f</Color>
            <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />

            <!--白底文字（用于彩色徽章上的白色文字）-->
            <SolidColorBrush x:Key="OnAccentBrush" Color="#ffffff" />

            <!--提示颜色-->
            <Color x:Key="WarningColor">#FFC408</Color>
            <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />

            <SolidColorBrush x:Key="GrayDark" Color="#e8e8ea" Opacity="0.65" />

            <!-- TabSwitch 容器 -->
            <SolidColorBrush x:Key="TabSwitchBgBrush" Color="#f0f0f0" />
            <SolidColorBrush x:Key="TabSwitchBorderBrush" Color="#e0e0e0" />

            <!-- 选项文字 -->
            <Color x:Key="TabOptionTextColor">#5b6877</Color>
            <Color x:Key="TabOptionTextCheckedColor">#1a2b3c</Color>

            <!-- 选中滑块 -->
            <SolidColorBrush x:Key="TabOptionSelectedBrush" Color="#ffffff" />
            <SolidColorBrush x:Key="TabSliderBorderBrush" Color="#d0d0d0" />
            <SolidColorBrush x:Key="TabOptionSelectedBorderBrush" Color="#c8c8c8" />

            <!-- Option 选项边框 -->
            <SolidColorBrush x:Key="OptionUncheckedBorderBrush" Color="#c8c8d0" />
            <SolidColorBrush x:Key="OptionCheckedBorderBrush" Color="{DynamicResource ThemeColor}" Opacity="0.80" />
            <SolidColorBrush x:Key="OptionCheckedBackgroundBrush" Color="{DynamicResource ThemeColor}" Opacity="0.15" />

            <!-- 时间轴 -->
            <SolidColorBrush x:Key="TimelineBgBrush" Color="#ffffff" />
            <SolidColorBrush x:Key="TimelineBorderBrush" Color="#e0e0e0" />
            <SolidColorBrush x:Key="TimelineHeaderBgBrush" Color="#ffffff" Opacity="0.7" />
            <SolidColorBrush x:Key="TimelineInactiveBrush" Color="#d5d5dd" />
            <SolidColorBrush x:Key="TimelineTickMajorBrush" Color="#c0c0c8" />
            <SolidColorBrush x:Key="TimelineTickHalfBrush" Color="#d5d5dd" />
            <SolidColorBrush x:Key="TimelineTickQuarterBrush" Color="#e0e0e8" />
            <SolidColorBrush x:Key="TimelineTickTextBrush" Color="#7e7e7e" />
            <SolidColorBrush x:Key="TimelineTimeLabelBrush" Color="#7e7e7e" Opacity="0.85" />
            <SolidColorBrush x:Key="TimelineNowBrush" Color="#2b20d9" />
            <SolidColorBrush x:Key="TimelineSelectBgBrush" Color="#2b20d9" Opacity="0.18" />
            <SolidColorBrush x:Key="TimelineSelectBorderBrush" Color="#2b20d9" Opacity="0.80" />
            <SolidColorBrush x:Key="TimelineTipBgBrush" Color="#ffffff" />
            <SolidColorBrush x:Key="TimelineTipBorderBrush" Color="#d0d0d8" />
            <SolidColorBrush x:Key="TimelineTipTextBrush" Color="#000000" />
            <SolidColorBrush x:Key="TimelineTipSubBrush" Color="#7e7e7e" />
            <SolidColorBrush x:Key="TimelineTrackBgBrush" Color="#e8e8ee" />
            <SolidColorBrush x:Key="TimelineTooltipShadowBrush" Color="#000000" Opacity="0.15" />
            <Color x:Key="TimelineIdleColor">#b0b0b0</Color>
            <Color x:Key="TimelineDefaultColor">#888888</Color>
            <SolidColorBrush x:Key="TimelineNowDotOuterBrush" Color="#cccccc" />

            <!-- 时间轴时段背景 -->
            <SolidColorBrush x:Key="TimelinePeriodNightBgBrush" Color="#d8e0f0" />
            <SolidColorBrush x:Key="TimelinePeriodMorningBgBrush" Color="#d0e8d0" />
            <SolidColorBrush x:Key="TimelinePeriodNoonBgBrush" Color="#e0e0e8" />
            <SolidColorBrush x:Key="TimelinePeriodAfternoonBgBrush" Color="#f0e4d8" />
            <SolidColorBrush x:Key="TimelinePeriodEveningBgBrush" Color="#e0d8f0" />

            <!-- 时间轴框选 -->
            <SolidColorBrush x:Key="TimelineSelectionMaskBrush" Color="#000000" Opacity="0.18" />
            <SolidColorBrush x:Key="TimelineSelectionBorderBrush" Color="#2b20d9" />
            <SolidColorBrush x:Key="TimelineSelectionGlowBrush" Color="#2b20d9" Opacity="0.1" />
            <SolidColorBrush x:Key="TimelineSelectionHandleBrush" Color="#2b20d9" />
            <SolidColorBrush x:Key="TimelineSelectionHandleBorderBrush" Color="#ffffff" />
            <SolidColorBrush x:Key="TimelineSelectionLabelBgBrush" Color="#ffffff" />
            <SolidColorBrush x:Key="TimelineSelectionLabelTextBrush" Color="#000000" />

            <!-- 多轨道时间轴 -->
            <SolidColorBrush x:Key="MultiTrackRowBgBrush" Color="#f2f2f6" />
            <SolidColorBrush x:Key="MultiTrackRowBorderBrush" Color="#d8d8e0" />
            <SolidColorBrush x:Key="MultiTrackIconBgBrush" Color="#e8e8f0" />
            <SolidColorBrush x:Key="MultiTrackTrackBgBrush" Color="#e2e2e8" />
            <SolidColorBrush x:Key="MultiTrackTrackBorderBrush" Color="#d0d0d8" />

            <!-- 颜色模式切换 -->
            <SolidColorBrush x:Key="ColorModeToggleBgBrush" Color="#E4E4EC" />
            <SolidColorBrush x:Key="ColorModeToggleBorderBrush" Color="#C8C8D4" />
            <SolidColorBrush x:Key="ColorModeToggleCheckedBgBrush" Color="#D0D0D8" />
            <SolidColorBrush x:Key="ColorModeToggleCheckedBorderBrush" Color="#B8B8C4" />
            <SolidColorBrush x:Key="ColorModeToggleCheckedTextBrush" Color="#2C2C34" />
            <SolidColorBrush x:Key="ColorModeToggleUncheckedTextBrush" Color="#8A8A96" />
            <SolidColorBrush x:Key="ColorModeToggleHoverTextBrush" Color="#4A4A54" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
