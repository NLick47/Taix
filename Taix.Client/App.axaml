<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Name="Taix"
             x:Class="Taix.Client.App">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Styles>
        <SimpleTheme />
        <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Simple/Simple.xaml" />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Resources/Themes/Common.axaml" />
                <ResourceInclude Source="/Resources/Themes/Theme.axaml" />
                <ResourceInclude Source="/Themes/Generic.axaml" />
                <!--<ResourceInclude Source="/Resources/Localization/StringResources.en.axaml"/>-->
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
        
        <ControlTheme x:Key="{x:Type WindowDrawnDecorations}" 
                      TargetType="WindowDrawnDecorations">
            <Setter Property="DefaultTitleBarHeight" Value="0"/>
            <Setter Property="DefaultFrameThickness" Value="0"/>
            <Setter Property="DefaultShadowThickness" Value="0"/>
            <Setter Property="Template">
                <WindowDrawnDecorationsTemplate>
                    <WindowDrawnDecorationsContent />
                </WindowDrawnDecorationsTemplate>
            </Setter>
        </ControlTheme>
    </Application.Resources>

</Application>