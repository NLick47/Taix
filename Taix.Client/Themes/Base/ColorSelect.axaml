<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:button="using:Taix.Client.Controls.Button"
                    xmlns:converter="using:Taix.Client.Controls.Converters"
                    xmlns:sys="using:System"
                    xmlns:controls="using:Taix.Client.Controls.Base"
                    xmlns:behaviors="using:Taix.Client.Behaviors">
    <converter:HextoColorConverter x:Key="HextoColorConverter" />
    <ControlTheme x:Key="{x:Type controls:ColorSelect}" TargetType="controls:ColorSelect">
        <Styles>
            <Style Selector="controls|ColorSelect:pointerover">
                <Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
            </Style>
        </Styles>

        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="#f7f8fa" CornerRadius="5"
                        BorderThickness="2" Width="38" Height="38">
                    <Interaction.Behaviors>
                        <EventTriggerBehavior EventName="PointerPressed">
                            <InvokeCommandAction
                                Command="{Binding ShowSelectCommand,RelativeSource={RelativeSource TemplatedParent}}" />
                        </EventTriggerBehavior>
                    </Interaction.Behaviors>

                    <Grid>
                        <Border CornerRadius="4" Width="28" Height="28"
                                Background="{TemplateBinding Color,Converter={StaticResource HextoColorConverter}}" />

                        <Popup
                            x:Name="Popup"
                            Placement="Bottom"
                            IsOpen="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsOpen, Mode=TwoWay}">
                            <Interaction.Behaviors>
                                <behaviors:PopupScrollDismissBehavior />
                            </Interaction.Behaviors>
                            <Border
                                x:Name="SelectContainer"
                                CornerRadius="10"
                                BorderBrush="{DynamicResource PopupBorderBrush}"
                                BorderThickness="1"
                                Background="{DynamicResource PopupBackgroundBrush}"
                                Padding="12"
                                Margin="10">
                                <Border.Effect>
                                    <DropShadowDirectionEffect
                                        BlurRadius="6" ShadowDepth="2"
                                        Direction="315" Color="Gray" Opacity=".1" />
                                </Border.Effect>

                                <StackPanel Spacing="12">
                                    <!-- 预设颜色 -->
                                    <TextBlock Text="{DynamicResource ChooseColor}" VerticalAlignment="Center"
                                               HorizontalAlignment="Left"
                                               FontSize="13"
                                               Foreground="{DynamicResource DefaultTextBrush}" />

                                    <ListBox
                                        x:Name="listBox"
                                        ItemsSource="{TemplateBinding Colors}"
                                        SelectedItem="{TemplateBinding Color}"
                                        ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.Styles>
                                            <Style Selector="ListBox">
                                                <Setter Property="Template">
                                                    <ControlTemplate>
                                                        <Border>
                                                            <ItemsPresenter ItemsPanel="{TemplateBinding ItemsPanel}" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter>
                                            </Style>
                                            <Style Selector="ListBoxItem">
                                                <Setter Property="Template">
                                                    <ControlTemplate>
                                                        <Border BorderBrush="Transparent"
                                                                BorderThickness="2" x:Name="Border"
                                                                Background="White" Margin="0,0,0,0"
                                                                Padding="0" Width="35" Height="35"
                                                                CornerRadius="5">
                                                            <ContentPresenter
                                                                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                Background="{TemplateBinding Background}"
                                                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                                                Content="{TemplateBinding Content}"
                                                                VerticalAlignment="Center"
                                                                HorizontalAlignment="Center" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter>
                                            </Style>
                                        </ListBox.Styles>

                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>

                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <WrapPanel x:DataType="sys:String" Orientation="Horizontal">
                                                    <Border Width="25" CornerRadius="4"
                                                            Height="25"
                                                            Background="{Binding .,Converter={StaticResource HextoColorConverter}}" />
                                                </WrapPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <!-- 自定义颜色切换按钮 -->
                                    <button:Button HorizontalAlignment="Stretch"
                                                   Command="{Binding ToggleCustomModeCommand,RelativeSource={RelativeSource TemplatedParent}}"
                                                   Content="{DynamicResource CustomColor}"
                                                   Height="32" />

                                    <!-- 自定义颜色选择器 -->
                                    <controls:ColorPicker x:Name="ColorPicker"
                                                          IsVisible="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsCustomMode}"
                                                          IsAlphaVisible="False" />
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>
