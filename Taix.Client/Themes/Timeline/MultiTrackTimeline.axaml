<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:timeline="using:Taix.Client.Controls.Timeline"
                    xmlns:base="using:Taix.Client.Controls.Base">

    <ControlTheme x:Key="{x:Type timeline:MultiTrackTimeline}" TargetType="timeline:MultiTrackTimeline">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate TargetType="timeline:MultiTrackTimeline">
                <Grid Grid.IsSharedSizeScope="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 时间刻度尺 -->
                    <Grid Grid.Row="0" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>

                        <!-- 左侧占位（宽度由 SharedSizeGroup 与数据行对齐） -->
                        <Border Grid.Column="0" />

                        <!-- 时间刻度 -->
                        <Border Grid.Column="1" Margin="16,0">
                            <timeline:MultiTrackTimeRuler
                                Date="{Binding Date, RelativeSource={RelativeSource TemplatedParent}}"
                                VisibleStartHour="{Binding VisibleStartHour, RelativeSource={RelativeSource TemplatedParent}}"
                                VisibleEndHour="{Binding VisibleEndHour, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Border>

                        <!-- 右侧占位（宽度由 SharedSizeGroup 与数据行对齐） -->
                        <Border Grid.Column="2" />
                    </Grid>

                    <!-- 数据行（可滚动，虚拟化） -->
                    <ScrollViewer Grid.Row="1"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <ListBox x:Name="PART_ItemsControl"
                                 ItemsSource="{TemplateBinding DataItems}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="0"
                                 Focusable="False">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,8" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Focusable" Value="False" />
                                <Setter Property="Cursor" Value="Hand" />
                            </Style>
                            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                            <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                            <Style Selector="ListBoxItem Border.row">
                                <Setter Property="Transitions">
                                    <Transitions>
                                        <BrushTransition Property="BorderBrush" Duration="0:0:0.2" />
                                    </Transitions>
                                </Setter>
                            </Style>
                            <Style Selector="ListBoxItem:pointerover Border.row">
                                <Setter Property="BorderBrush" Value="{DynamicResource ChartCardHoverBorderBrush}" />
                            </Style>
                            <Style Selector="ListBoxItem Border.hover-overlay">
                                <Setter Property="Opacity" Value="0" />
                                <Setter Property="Transitions">
                                    <Transitions>
                                        <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
                                    </Transitions>
                                </Setter>
                            </Style>
                            <Style Selector="ListBoxItem:pointerover Border.hover-overlay">
                                <Setter Property="Opacity" Value="0.06" />
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="timeline:MultiTrackTimelineItem">
                                <Border Height="64"
                                        CornerRadius="8"
                                        Background="{DynamicResource MultiTrackRowBgBrush}"
                                        BorderBrush="{DynamicResource MultiTrackRowBorderBrush}"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        ClipToBounds="True"
                                        Classes="row">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                        </Grid.ColumnDefinitions>

                                        <!-- 左侧：图标 + 名称/分类 -->
                                        <Border Grid.Column="0"
                                                VerticalAlignment="Center"
                                                Margin="14,0,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="auto" />
                                                    <ColumnDefinition Width="auto" />
                                                </Grid.ColumnDefinitions>

                                                <!-- 图标 -->
                                                <Border Background="{DynamicResource MultiTrackIconBgBrush}"
                                                        CornerRadius="8"
                                                        Width="42"
                                                        Height="42"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center">
                                                    <base:Img URL="{Binding Icon}"
                                                              Width="30"
                                                              Height="30"
                                                              DecodeWidth="30"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                                </Border>

                                                <StackPanel Grid.Column="1"
                                                            VerticalAlignment="Center"
                                                            Margin="12,0,0,0"
                                                            MaxWidth="120">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource DefaultTextBrush}"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <Border CornerRadius="3"
                                                            Padding="5,1"
                                                            Margin="0,3,0,0"
                                                            HorizontalAlignment="Left"
                                                            IsVisible="{Binding CategoryName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                        <Border.Background>
                                                            <SolidColorBrush Color="{Binding CategoryColor}"
                                                                             Opacity="0.25" />
                                                        </Border.Background>
                                                        <TextBlock Text="{Binding CategoryName}"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource SubTextBrush}" />
                                                    </Border>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- 中间：轨道 -->
                                        <Border Grid.Column="1"
                                                Height="36"
                                                VerticalAlignment="Center"
                                                Margin="16,0"
                                                CornerRadius="6"
                                                Background="{DynamicResource MultiTrackTrackBgBrush}"
                                                BorderBrush="{DynamicResource MultiTrackTrackBorderBrush}"
                                                BorderThickness="1"
                                                ClipToBounds="True">
                                            <timeline:MultiTrackRow
                                                Segments="{Binding Segments}"
                                                UseCategoryColor="{Binding UseCategoryColor,
                                                    RelativeSource={RelativeSource AncestorType=timeline:MultiTrackTimeline}}"
                                                VisibleStartHour="{Binding VisibleStartHour,
                                                    RelativeSource={RelativeSource AncestorType=timeline:MultiTrackTimeline}}"
                                                VisibleEndHour="{Binding VisibleEndHour,
                                                    RelativeSource={RelativeSource AncestorType=timeline:MultiTrackTimeline}}" />
                                        </Border>

                                        <!-- 右侧：时长 + 百分比 -->
                                        <StackPanel Grid.Column="2"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,16,0"
                                                    MinWidth="68">
                                            <TextBlock Text="{Binding DurationText}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource StandardTextBrush}"
                                                       HorizontalAlignment="Right" />
                                            <TextBlock Text="{Binding Percentage, StringFormat='{}{0:F1}%'}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SubTextBrush}"
                                                       Margin="0,2,0,0"
                                                       HorizontalAlignment="Right" />
                                        </StackPanel>
                                        <!-- Hover overlay -->
                                        <Border Grid.ColumnSpan="3" CornerRadius="8" IsHitTestVisible="False"
                                                Classes="hover-overlay" Background="#FFFFFF" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    </ScrollViewer>
                </Grid>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

</ResourceDictionary>
