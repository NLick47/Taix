<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:timeline="using:Taix.Client.Controls.Timeline"
                    xmlns:base="using:Taix.Client.Controls.Base">

    <ControlTheme x:Key="{x:Type timeline:MultiTrackTimeline}" TargetType="timeline:MultiTrackTimeline">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate TargetType="timeline:MultiTrackTimeline">
                <Grid Grid.IsSharedSizeScope="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 时间刻度尺 -->
                    <Grid Grid.Row="0" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="72" />
                        </Grid.ColumnDefinitions>

                        <!-- 左侧占位 -->
                        <Border Grid.Column="0" />

                        <!-- 时间刻度 -->
                        <Border Grid.Column="1" Margin="12,0">
                            <timeline:MultiTrackTimeRuler
                                Date="{Binding Date, RelativeSource={RelativeSource TemplatedParent}}"
                                VisibleStartHour="{Binding VisibleStartHour, RelativeSource={RelativeSource TemplatedParent}}"
                                VisibleEndHour="{Binding VisibleEndHour, RelativeSource={RelativeSource TemplatedParent}}"
                                BoundStartHour="{Binding FrameStartHour, RelativeSource={RelativeSource TemplatedParent}}"
                                BoundEndHour="{Binding FrameEndHour, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Border>

                        <!-- 右侧占位 -->
                        <Border Grid.Column="2" />
                    </Grid>

                    <!-- 数据行 -->
                    <ScrollViewer Grid.Row="1"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <ListBox x:Name="PART_ItemsControl"
                                 ItemsSource="{TemplateBinding DataItems}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="0"
                                 Focusable="False">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,8" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Focusable" Value="False" />
                                <Setter Property="Cursor" Value="Hand" />
                            </Style>
                            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                            <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                            <Style Selector="ListBoxItem Border.row">
                                <Setter Property="Transitions">
                                    <Transitions>
                                        <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                                        <BrushTransition Property="Background" Duration="0:0:0.15" />
                                    </Transitions>
                                </Setter>
                            </Style>
                            <Style Selector="ListBoxItem:pointerover Border.row">
                                <Setter Property="BorderBrush" Value="{DynamicResource ChartCardHoverBorderBrush}" />
                                <Setter Property="Background" Value="{DynamicResource MultiTrackRowHoverBgBrush}" />
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="timeline:MultiTrackTimelineItem">
                                <Border Height="70"
                                        CornerRadius="10"
                                        Background="{DynamicResource MultiTrackRowBgBrush}"
                                        BorderBrush="{DynamicResource MultiTrackRowBorderBrush}"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        ClipToBounds="False"
                                        Classes="row">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="72" />
                                        </Grid.ColumnDefinitions>

                                        <!-- 左侧：颜色标记 + 图标 + 名称 + 分类 -->
                                        <Border Grid.Column="0"
                                                VerticalAlignment="Center"
                                                Margin="10,0,0,0">
                                            <Grid RowDefinitions="Auto,Auto"
                                                  ColumnDefinitions="Auto,Auto,*">

                                                <Rectangle Grid.Row="0"
                                                           Grid.RowSpan="2"
                                                           Width="4"
                                                           Height="36"
                                                           Fill="{Binding Color}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,10,0"
                                                           RadiusX="2"
                                                           RadiusY="2" />

                                                <!-- 图标 -->
                                                <Border Grid.Column="1"
                                                        Grid.Row="0"
                                                        Grid.RowSpan="2"
                                                        Background="{DynamicResource MultiTrackIconBgBrush}"
                                                        CornerRadius="8"
                                                        Width="34"
                                                        Height="34"
                                                        VerticalAlignment="Center">
                                                    <base:Img URL="{Binding Icon}"
                                                              Width="20"
                                                              Height="20"
                                                              DecodeWidth="20"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                                </Border>

                                                <TextBlock Grid.Column="2"
                                                           Grid.Row="0"
                                                           Text="{Binding Name}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource DefaultTextBrush}"
                                                           VerticalAlignment="Bottom"
                                                           Margin="8,0,4,1"
                                                           TextTrimming="CharacterEllipsis" />

                                                <TextBlock Grid.Column="2"
                                                           Grid.Row="1"
                                                           Text="{Binding CategoryName}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource SubTextBrush}"
                                                           VerticalAlignment="Top"
                                                           Margin="8,1,4,0"
                                                           TextTrimming="CharacterEllipsis"
                                                           IsVisible="{Binding CategoryName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                            </Grid>
                                        </Border>

                                        <!-- 中间：轨道 -->
                                        <Border Grid.Column="1"
                                                Height="36"
                                                VerticalAlignment="Center"
                                                Margin="12,0"
                                                CornerRadius="8"
                                                ClipToBounds="False"
                                                Background="{DynamicResource MultiTrackTrackBgBrush}"
                                                BorderBrush="{DynamicResource MultiTrackTrackBorderBrush}"
                                                BorderThickness="1">
                                            <timeline:MultiTrackRow
                                                Segments="{Binding Segments}"
                                                VisibleStartHour="{Binding VisibleStartHour,
                                                    RelativeSource={RelativeSource AncestorType=timeline:MultiTrackTimeline}}"
                                                VisibleEndHour="{Binding VisibleEndHour,
                                                    RelativeSource={RelativeSource AncestorType=timeline:MultiTrackTimeline}}" />
                                        </Border>

                                        <!-- 右侧：时长 -->
                                        <StackPanel Grid.Column="2"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Right"
                                                    Margin="0,0,12,0">
                                            <TextBlock Text="{Binding DurationText}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource StandardTextBrush}"
                                                       HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    </ScrollViewer>
                </Grid>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

</ResourceDictionary>
