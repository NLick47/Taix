<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:input="using:Taix.Client.Controls.Input"
                    xmlns:models="using:Taix.Client.Controls.Charts.Model"
                    xmlns:controls="using:Taix.Client.Controls.Charts">

    <ControlTheme x:Key="{x:Type controls:ListChart}" TargetType="controls:ListChart">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Background" Value="Transparent" />
        <Styles>
            <Style Selector="controls|ListChart[IsSearch=True] /template/ Grid#SearchHeader">
                <Setter Property="IsVisible" Value="True" />
            </Style>
        </Styles>
        <Setter Property="Template">
            <ControlTemplate>
                <Grid Background="{TemplateBinding Background}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid x:Name="SearchHeader" IsVisible="False">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock FontSize="14" Foreground="{DynamicResource SubTextBrush}">
                            <Run Text="{DynamicResource Aggregate}" />
                            <Run x:Name="CountText" />
                            <Run Text="{DynamicResource Piece}" />
                        </TextBlock>
                        <input:InputBox
                            IconColor="{DynamicResource DefaultTextBrush}"
                            x:Name="SearchBox" Grid.Row="1"
                            Placeholder="{DynamicResource Search}"
                            Margin="0,10,0,10"
                            BoxPadding="5,0"
                            Icon="Search" />
                    </Grid>


                    <ListBox x:Name="ListView" Grid.Row="1"
                             ContextMenu="{TemplateBinding ItemMenu}">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.Styles>
                            <Style Selector="ListBox">
                                <Setter Property="Template">
                                    <ControlTemplate>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <ItemsPresenter ItemsPanel="{TemplateBinding ItemsPanel}" />
                                        </ScrollViewer>
                                    </ControlTemplate>
                                </Setter>
                            </Style>

                            <Style Selector="ListBox.noScroll">
                                <Setter Property="Template">
                                    <ControlTemplate>
                                        <ItemsPresenter ItemsPanel="{TemplateBinding ItemsPanel}" />
                                    </ControlTemplate>
                                </Setter>
                            </Style>

                            <Style Selector="ListBoxItem">
                                <Style Selector="^:pointerover /template/ ContentPresenter">
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                                <Style Selector="^:selected /template/ ContentPresenter">
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                                <Style Selector="^:selected:focus /template/ ContentPresenter">
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                                <Style Selector="^:selected:pointerover /template/ ContentPresenter">
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                                <Style Selector="^:selected:focus:pointerover /template/ ContentPresenter">
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                                <Setter Property="Template">
                                    <ControlTemplate>
                                        <ContentPresenter Name="PART_ContentPresenter"
                                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                                          Content="{TemplateBinding Content}" />
                                    </ControlTemplate>
                                </Setter>
                            </Style>
                        </ListBox.Styles>

                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:ChartsDataModel">
                                <Border>
                                    <controls:ChartsItemTypeList
                                        IconSize="{Binding RelativeSource={RelativeSource AncestorType={x:Type controls:ListChart}}, Path=IconSize}"
                                        Data="{Binding}"
                                        MaxValue="{Binding RelativeSource={RelativeSource AncestorType={x:Type controls:ListChart}}, Path=DataMaxValue}"
                                        IsShowBadge="{Binding RelativeSource={RelativeSource AncestorType={x:Type controls:ListChart}}, Path=IsShowBadge}" />
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>
