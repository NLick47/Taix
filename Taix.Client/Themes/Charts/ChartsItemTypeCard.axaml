<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:base="clr-namespace:Taix.Client.Controls.Base"
                    xmlns:controls="using:Taix.Client.Controls.Charts">

    <ControlTheme x:Key="{x:Type controls:ChartsItemTypeCard}"
                  TargetType="controls:ChartsItemTypeCard">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Margin" Value="8" />

        <Styles>
            <Style Selector="controls|ChartsItemTypeCard">
                <Style Selector="^ /template/ Border#Normal">
                    <Setter Property="Transitions">
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.25" />
                        </Transitions>
                    </Setter>
                </Style>

                <Style Selector="^:pointerover /template/ Border#Normal">
                    <Setter Property="Opacity" Value="1" />
                </Style>

                <Style Selector="^:pointerover /template/ Border#Border">
                    <Setter Property="BorderBrush" Value="{DynamicResource ThemeColor}" />
                </Style>

                <Style Selector="^ /template/ Border#Border">
                    <Setter Property="Transitions">
                        <Transitions>
                            <BrushTransition Property="BorderBrush" Duration="0:0:0.3" />
                        </Transitions>
                    </Setter>
                </Style>

                <Style Selector="^[IsLoading=True]">
                    <Style Selector="^ /template/ base|Placeholder#Loading">
                        <Setter Property="IsVisible" Value="true" />
                    </Style>
                    <Style Selector="^ /template/ Border#Normal">
                        <Setter Property="IsVisible" Value="false" />
                    </Style>
                </Style>
            </Style>
        </Styles>

        <Setter Property="Template">
            <ControlTemplate>
                <Grid>
                    <Border x:Name="Normal" CornerRadius="18">
                        <Border.Effect>
                            <DropShadowDirectionEffect
                                BlurRadius="20" Direction="0" ShadowDepth="0"
                                Color="{DynamicResource ThemeColor}" Opacity="0" />
                        </Border.Effect>
                        <Border x:Name="Border"
                                BorderThickness="1"
                                Background="{DynamicResource ChartCardGlassBgBrush}"
                                BorderBrush="{DynamicResource ChartCardGlassBorderBrush}"
                                CornerRadius="18" Width="150"
                                Height="150">
                            <Border.Clip>
                                <RectangleGeometry Rect="0,0,150,150" />
                            </Border.Clip>
                            <Grid>
                                <!-- 背景微渐变层 -->
                                <Border CornerRadius="18" IsHitTestVisible="False">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                            <GradientStop Offset="0" Color="#0fffffff" />
                                            <GradientStop Offset="0.55" Color="#06ffffff" />
                                            <GradientStop Offset="1" Color="#03ffffff" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>

                                <!-- 顶部高光条 -->
                                <Border Height="1.5" VerticalAlignment="Top" Margin="14,0,14,0" IsHitTestVisible="False" CornerRadius="0.75">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                            <GradientStop Offset="0" Color="#00ffffff" />
                                            <GradientStop Offset="0.5" Color="#55ffffff" />
                                            <GradientStop Offset="1" Color="#00ffffff" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>

                                <base:Img x:Name="IconObj" Width="32" Height="32" HorizontalAlignment="Center"
                                                 DecodeWidth="64"
                                                 URL="{Binding Data.Icon,RelativeSource={RelativeSource AncestorType={x:Type controls:ChartsItemTypeCard}}}"
                                                 VerticalAlignment="Center" />

                                <TextBlock x:Name="NameTextObj"
                                           Text="{Binding RelativeSource={RelativeSource AncestorType={x:Type controls:ChartsItemTypeCard}},Path=Data.Name}"
                                           Foreground="{DynamicResource WhiteBgTextBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="10,0,10,12"
                                           FontSize="13" />

                                <!-- 药丸标签 -->
                                <Border VerticalAlignment="Top" CornerRadius="12" Padding="7,4" HorizontalAlignment="Left"
                                        Margin="10,10,0,0"
                                        Background="{DynamicResource ChartCardPillBgBrush}">
                                    <TextBlock x:Name="ValueTextObj" Foreground="{DynamicResource ChartCardPillTextBrush}" FontSize="11" FontWeight="SemiBold" />
                                </Border>
                            </Grid>
                        </Border>
                    </Border>
                    <base:Placeholder x:Name="Loading" IsVisible="False" CornerRadius="18" Width="150" Height="150" />
                </Grid>
            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>
