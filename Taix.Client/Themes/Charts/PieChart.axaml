<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="using:Taix.Client.Controls.Charts">
    <ControlTheme x:Key="{x:Type controls:PieChart}" TargetType="controls:PieChart">
        <Setter Property="Template">
            <ControlTemplate>
                <Canvas x:Name="PieCanvas" />
            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>
