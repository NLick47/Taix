<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:base="using:Taix.Client.Controls.Base"
                    xmlns:list="using:Taix.Client.Controls.List"
                    xmlns:controls="using:Taix.Client.Controls.DatePickerBar"
                    xmlns:behaviors="using:Taix.Client.Behaviors">

    <ControlTheme x:Key="{x:Type controls:DatePickerBar}" TargetType="controls:DatePickerBar">
        <Styles>
            <Style Selector="controls|DatePickerBar[ShowType=Year]">
                <Style Selector="^ /template/ Grid#ItemSelect">
                    <Setter Property="IsVisible" Value="False" />
                </Style>
            </Style>

            <Style Selector="controls|DatePickerBar:pointerover  /template/ Border#Date">
                <Setter Property="Background" Value="{DynamicResource DatePickerHoverGlassBrush}" />
            </Style>

            <Style Selector="controls|DatePickerBar[IsShowDatePickerPopup=True]  /template/ base|Icon#PopupIcon">
                <Setter Property="RenderTransform" Value="rotate(-180deg)" />
                <Setter Property="Foreground" Value="{DynamicResource ThemeColor}" />
            </Style>
        </Styles>
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border>
                    <StackPanel>
                        <Grid x:Name="header">
                            <Border
                                x:Name="Date"
                                Background="{DynamicResource DatePickerGlassBackgroundBrush}"
                                Padding="15,8"
                                CornerRadius="12"
                                Margin="0,0,0,10"
                                HorizontalAlignment="Left"
                                ToolTip.Tip="{DynamicResource Select}"
                                BorderBrush="{DynamicResource DatePickerGlassBorderBrush}"
                                BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <base:Icon x:Name="DateIcon" Margin="0,0,5,0" IconType="Calendar"
                                               Foreground="{DynamicResource StandardTextBrush}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right" />

                                    <TextBlock Foreground="{DynamicResource StandardTextBrush}"
                                               FontSize="15" Text="{TemplateBinding SelectedDateString}"
                                               Margin="0,0" VerticalAlignment="Center"
                                               HorizontalAlignment="Left" />
                                    <base:Icon x:Name="PopupIcon" Width="25" Height="25"
                                               Margin="10,0,0,0" FontSize="10" IconType="ChevronDown"
                                               VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <base:Icon.RenderTransform>
                                            <RotateTransform Angle="0" CenterX="12.5" CenterY="12.5" />
                                        </base:Icon.RenderTransform>

                                        <base:Icon.Transitions>
                                            <Transitions>
                                                <TransformOperationsTransition
                                                    Property="RenderTransform"
                                                    Duration="0.18" />

                                                <BrushTransition Property="Foreground" Duration="0.18" />
                                            </Transitions>
                                        </base:Icon.Transitions>
                                    </base:Icon>
                                </StackPanel>

                                <Border.Transitions>
                                    <Transitions>
                                        <BrushTransition Property="Background" Duration="0.18" />

                                    </Transitions>
                                </Border.Transitions>
                            </Border>

                            <Popup
                                x:Name="DatePickerPopup"
                                IsOpen="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsShowDatePickerPopup, Mode=TwoWay}"
                                Placement="Bottom"
                                PlacementTarget="{Binding ElementName=Date}">
                                <Interaction.Behaviors>
                                    <behaviors:PopupScrollDismissBehavior />
                                </Interaction.Behaviors>
                                <Border
                                    Background="{DynamicResource SettingPanelBgBrush}"
                                    CornerRadius="12"
                                    Padding="15"
                                    Margin="8">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="20" Color="#000000" Opacity="0.15" OffsetX="0" OffsetY="8" />
                                    </Border.Effect>

                                    <StackPanel Spacing="12">
                                        <StackPanel>
                                            <TextBlock Text="{DynamicResource Year}" HorizontalAlignment="Center"
                                                       FontWeight="Medium" FontSize="13"
                                                       Foreground="{DynamicResource SubTextBrush}"
                                                       Margin="0,0,0,8" />
                                            <UniformGrid x:Name="YearsGrid" Columns="4" Rows="2"
                                                         Width="200" Height="80" />
                                        </StackPanel>
                                        <StackPanel x:Name="MonthSelect" IsVisible="False">
                                            <TextBlock Text="{DynamicResource Month}" HorizontalAlignment="Center"
                                                       FontWeight="Medium" FontSize="13"
                                                       Foreground="{DynamicResource SubTextBrush}"
                                                       Margin="0,0,0,8" />
                                            <UniformGrid x:Name="MonthsGrid" Columns="4" Rows="3"
                                                         Width="200" Height="120" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>

                        <Grid x:Name="ItemSelect">
                            <Border Background="{DynamicResource StandardBackgroundBrush}"
                                    Padding="10" CornerRadius="10" Margin="0,10,0,0">
                                <ScrollViewer x:Name="ScrollViewer" VerticalScrollBarVisibility="Disabled"
                                              HorizontalScrollBarVisibility="Hidden">
                                    <StackPanel
                                        Orientation="Horizontal"
                                        x:Name="Container" />
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>