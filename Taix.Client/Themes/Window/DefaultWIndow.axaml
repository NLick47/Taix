<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:button="using:Taix.Client.Controls.Button"
                    xmlns:base="using:Taix.Client.Controls.Base"
                    xmlns:input="using:Taix.Client.Controls.Input"
                    xmlns:controls="using:Taix.Client.Controls.Window"
    xmlns:system="clr-namespace:System;assembly=System.Runtime">

    <system:Double x:Key="WindowTitleBarHeight">40</system:Double>

    <ControlTheme x:Key="{x:Type controls:DefaultWindow}"
                  TargetType="controls:DefaultWindow">
        <Setter Property="ExtendClientAreaToDecorationsHint"
                Value="True" />
        <Setter Property="ExtendClientAreaTitleBarHeightHint" Value="40" />
        <Setter Property="WindowDecorations" Value="None" />
        <!-- <Setter Property="ExtendClientAreaChromeHints" Value="NoChrome" /> -->
        
        <Setter Property="Foreground" Value="{DynamicResource StandardTextBrush}" />
        <Setter Property="UseLayoutRounding" Value="True" />

        <Styles>
            <Style Selector="controls|DefaultWindow[WindowState=Maximized] /template/ Border#WindowBorder">
                <Setter Property="Margin" Value="0" />
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="BoxShadow" Value="none" />
            </Style>
            <Style Selector="controls|DefaultWindow[WindowState=Maximized] /template/ Border#ContentBorder">
                <Setter Property="CornerRadius" Value="0" />
            </Style>
            <Style Selector="controls|DefaultWindow[WindowState=Maximized] /template/ Border#GlassHighlightBorder">
                <Setter Property="CornerRadius" Value="0" />
            </Style>
            <Style Selector="controls|DefaultWindow">
                <Style Selector="^ /template/ button|IconButton#BackBtn">
                    <Setter Property="Transitions">
                        <Transitions>
                            <DoubleTransition Property="Width" Duration="0.1" />
                        </Transitions>
                    </Setter>
                </Style>

                <Style Selector="^[IsCanBack=True] /template/ button|IconButton#BackBtn">
                    <Setter Property="Width" Value="35" />
                </Style>

                <Style Selector="^[ToastType=Success]">
                    <Style Selector="^ /template/ Border#ToastBorder">
                        <Setter Property="Background" Value="#24bf5f" />
                    </Style>

                    <Style Selector="^ /template/ base|Icon#ToastIcon">
                        <Setter Property="Foreground" Value="#fff" />
                    </Style>

                    <Style Selector="^ /template/ TextBlock#ToastText">
                        <Setter Property="Foreground" Value="#fff" />
                    </Style>
                </Style>


                <Style Selector="^[ToastType=Error]">
                    <Style Selector="^ /template/ Border#ToastBorder">
                        <Setter Property="Background" Value="#f54f4e" />
                    </Style>

                    <Style Selector="^ /template/ base|Icon#ToastIcon">
                        <Setter Property="Foreground" Value="#fff" />
                    </Style>

                    <Style Selector="^ /template/ TextBlock#ToastText">
                        <Setter Property="Foreground" Value="#fff" />
                    </Style>
                </Style>
            </Style>
        </Styles>
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="WindowBorder"   
                        CornerRadius="12"
                        BoxShadow="0 12 40 0 #28000000"
                        ClipToBounds="False"
                        Margin="16">
                    <Border x:Name="ContentBorder"
                        CornerRadius="12"
                        BorderThickness="1"
                        ClipToBounds="True"
                        BorderBrush="{DynamicResource WindowBorderBrush}"
                        Background="{DynamicResource WindowBackground}">
                        <Grid>
                            <!-- 原有窗口内容 -->
                            <Grid x:Name="WindowContent">
                            <!--标题栏-->
                            <Grid
                                x:Name="TitleBar"
                                Panel.ZIndex="999"
                                Height="{DynamicResource WindowTitleBarHeight}"
                                VerticalAlignment="Top"
                                Background="Transparent">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0"
                                      Panel.ZIndex="3">
                                    <StackPanel Orientation="Horizontal" Margin="15,0,0,0"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center">
                                        <button:IconButton Width="0"
                                                           VerticalAlignment="Center"
                                                           ToolTip.Tip="{DynamicResource Back}"
                                                           FontSize="10"
                                                           x:Name="BackBtn"
                                                           Command="{x:Static controls:DefaultWindow.BackCommand}"
                                                           Icon="Back" />

                                        <Panel VerticalAlignment="Center">
                                            <Image Source="{TemplateBinding IconSource}" VerticalAlignment="Center"
                                                   Stretch="Uniform" Width="18" />
                                            <Border x:Name="StatusDot"
                                                    Width="8" Height="8"
                                                    CornerRadius="4"
                                                    Background="#999999"
                                                    BorderBrush="{DynamicResource WindowBackground}"
                                                    BorderThickness="1.5"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Bottom"
                                                    Margin="0,0,-2,-2">
                                                <Border.Styles>
                                                    <Style Selector="Border">
                                                        <Style.Animations>
                                                            <Animation Duration="0:0:4"
                                                                       IterationCount="INFINITE">
                                                                <KeyFrame Cue="0%">
                                                                    <Setter Property="Opacity" Value="1.0" />
                                                                </KeyFrame>
                                                                <KeyFrame Cue="50%">
                                                                    <Setter Property="Opacity" Value="0.8" />
                                                                </KeyFrame>
                                                                <KeyFrame Cue="100%">
                                                                    <Setter Property="Opacity" Value="1.0" />
                                                                </KeyFrame>
                                                            </Animation>
                                                        </Style.Animations>
                                                    </Style>
                                                </Border.Styles>
                                            </Border>
                                        </Panel>
                                        <TextBlock VerticalAlignment="Center" Text="{TemplateBinding Title}"
                                                   IsEnabled="{TemplateBinding IsActive}"
                                                   Foreground="{DynamicResource DefaultTextBrush}" Margin="15,0,0,0" />
                                    </StackPanel>


                                </Grid>
                                <Grid Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top"

                                      Panel.ZIndex="3">
                                    <StackPanel Orientation="Horizontal">
                                        <button:IconButton
                                            x:Name="MinimizeButton"
                                            ToolTip.Tip="{DynamicResource Minimization}"
                                            Width="46"
                                            Height="32"
                                            FontSize="10"
                                            Icon="ChromeMinimize"
                                            Command="{x:Static controls:DefaultWindow.MinimizeWindowCommand}"
                                            IsVisible="True" />
                                        <button:IconButton
                                            x:Name="MaximizeButton"
                                            ToolTip.Tip="{DynamicResource Maximize}"
                                            Width="46"
                                            Height="32"
                                            FontSize="10"
                                            Icon="ChromeMaximize"
                                            Command="{x:Static controls:DefaultWindow.MaximizeWindowCommand}"
                                            IsVisible="{TemplateBinding MaximizeVisible}" />
                                        <button:IconButton
                                            x:Name="RestoreButton"
                                            ToolTip.Tip="{DynamicResource Restore}"
                                            Width="46"
                                            Height="32"
                                            FontSize="10"
                                            Icon="ChromeRestore"
                                            Command="{x:Static controls:DefaultWindow.RestoreWindowCommand}"
                                            IsVisible="{TemplateBinding RestoreVisible}" />
                                        <button:IconButton
                                            ToolTip.Tip="{DynamicResource Close}"
                                            Width="46"
                                            Height="32"
                                            FontSize="10"
                                            Icon="ChromeClose"
                                            Command="{x:Static controls:DefaultWindow.CloseWindowCommand}"
                                            IsVisible="True" />

                                    </StackPanel>
                                </Grid>
                            </Grid>
                            <ContentPresenter Content="{TemplateBinding Content}" Grid.Row="1" />

                            <!--提醒框-->
                            <Grid ZIndex="999" x:Name="ToastGrid" IsVisible="False">
                                <!--内容-->
                                <Border
                                    Padding="16,14"
                                    CornerRadius="14"
                                    MaxWidth="340"
                                    x:Name="ToastBorder"
                                    Background="{DynamicResource WindowContentBackground}"
                                    BorderBrush="{DynamicResource WindowBorderBrush}"
                                    BorderThickness="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top" ZIndex="99999">
                                    <Border.RenderTransform>
                                        <TransformGroup>
                                            <TranslateTransform Y="-150" />
                                        </TransformGroup>
                                    </Border.RenderTransform>

                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="20" Color="Black" Opacity="0.12" OffsetX="0" OffsetY="6" />
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30" />
                                            <ColumnDefinition Width="*" />

                                        </Grid.ColumnDefinitions>
                                        <base:Icon IconType="{TemplateBinding ToastIcon}"
                                                   VerticalAlignment="Top" Margin="0,0,10,0" x:Name="ToastIcon" />
                                        <TextBlock x:Name="ToastText" Grid.Column="1"
                                                   Text="{TemplateBinding ToastContent}" VerticalAlignment="Top"
                                                   TextWrapping="WrapWithOverflow" />
                                    </Grid>
                                </Border>

                                <!--Dialog-->
                                <Border
                                    Padding="24,20"
                                    CornerRadius="16"
                                    Width="340"
                                    x:Name="DialogBorder" 
                                    Background="{DynamicResource WindowContentBackground}"
                                    BorderBrush="{DynamicResource WindowBorderBrush}"
                                    BorderThickness="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top" ZIndex="1000">
                                    <Border.RenderTransform>
                                        <TransformGroup>
                                            <TranslateTransform Y="-150" />
                                        </TransformGroup>
                                    </Border.RenderTransform>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="24" Color="Black" Opacity="0.15" OffsetX="0" OffsetY="8" />
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="auto" />
                                            <RowDefinition Height="auto" />
                                            <RowDefinition Height="auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{TemplateBinding DialogTitle}" 
                                                   FontSize="18" 
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource StandardTextBrush}"
                                                   Margin="0,0,0,4" />
                                        <TextBlock Grid.Row="1" 
                                                   Text="{TemplateBinding DialogMessage}"
                                                   FontSize="14"
                                                   LineHeight="22"
                                                   Foreground="{DynamicResource SubTextBrush}"
                                                   TextWrapping="Wrap" />
                                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                                                    Margin="0,20,0,0">
                                            <button:Button x:Name="CancelBtn" Width="100"
                                                           Background="{DynamicResource StandardBackgroundBrush2}"
                                                           Foreground="{DynamicResource StandardTextBrush}"
                                                           Content="{DynamicResource Cancel}" />
                                            <button:Button x:Name="ConfirmBtn"
                                                           Background="{DynamicResource ThemeBrush}" Foreground="White"
                                                           Width="100" Margin="12,0,0,0"
                                                           Content="{DynamicResource Confirm}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!--Action Dialog-->
                                <Border
                                    Padding="24,20"
                                    CornerRadius="16"
                                    Width="360"
                                    x:Name="ActionDialogBorder"
                                    Background="{DynamicResource WindowContentBackground}"
                                    BorderBrush="{DynamicResource WindowBorderBrush}"
                                    BorderThickness="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top" ZIndex="1000">
                                    <Border.RenderTransform>
                                        <TransformGroup>
                                            <TranslateTransform Y="-150" />
                                        </TransformGroup>
                                    </Border.RenderTransform>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="24" Color="Black" Opacity="0.15" OffsetX="0" OffsetY="8" />
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="auto" />
                                            <RowDefinition Height="auto" />
                                            <RowDefinition Height="auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{TemplateBinding DialogTitle}" 
                                                   FontSize="18" 
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource StandardTextBrush}"
                                                   Margin="0,0,0,4" />
                                        <TextBlock Grid.Row="1" 
                                                   Text="{TemplateBinding DialogMessage}"
                                                   FontSize="14"
                                                   LineHeight="22"
                                                   Foreground="{DynamicResource SubTextBrush}"
                                                   TextWrapping="Wrap" />
                                        <StackPanel Grid.Row="2" x:Name="ActionDialogButtonsPanel"
                                                    Orientation="Horizontal" HorizontalAlignment="Right"
                                                    Margin="0,20,0,0" />
                                    </Grid>
                                </Border>

                                <!--Dialog-->
                                <Border
                                    Padding="24,20"
                                    CornerRadius="16"
                                    Width="380"
                                    x:Name="InputModalBorder"
                                    Background="{DynamicResource WindowContentBackground}"
                                    BorderBrush="{DynamicResource WindowBorderBrush}"
                                    BorderThickness="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top" ZIndex="1000">
                                    <Border.RenderTransform>
                                        <TransformGroup>
                                            <TranslateTransform Y="-150" />
                                        </TransformGroup>
                                    </Border.RenderTransform>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="24" Color="Black" Opacity="0.15" OffsetX="0" OffsetY="8" />
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="auto" />
                                            <RowDefinition Height="auto" />
                                            <RowDefinition Height="auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{TemplateBinding DialogTitle}" 
                                                   FontSize="18" 
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource StandardTextBrush}"
                                                   Margin="0,0,0,4" />
                                        <Border Grid.Row="1" Margin="0,4,0,0">
                                            <input:InputBox x:Name="InputModalInputBox"
                                                            Placeholder="{TemplateBinding DialogMessage}" />
                                        </Border>
                                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                                                    Margin="0,20,0,0">
                                            <button:Button x:Name="InputModalCancelBtn" Width="100"
                                                           Background="{DynamicResource StandardBackgroundBrush2}"
                                                           Foreground="{DynamicResource StandardTextBrush}">
                                                取消
                                            </button:Button>
                                            <button:Button x:Name="InputModalConfirmBtn"
                                                           Background="{DynamicResource ThemeBrush}" Foreground="White"
                                                           Width="100" Margin="12,0,0,0">
                                                确定
                                            </button:Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!--遮罩层-->
                                <Border x:Name="Masklayer" Background="Black" Opacity="0" />
                            </Grid>
                            
                             <Panel ZIndex="10000" IsHitTestVisible="True">
                                 <Border Width="8" HorizontalAlignment="Left"  VerticalAlignment="Stretch"
                                         Background="Transparent"
                                         WindowDecorationProperties.ElementRole="ResizeW"/>
                                 <Border Width="8" HorizontalAlignment="Right" VerticalAlignment="Stretch"
                                         Background="Transparent"
                                         WindowDecorationProperties.ElementRole="ResizeE"/>
                                <Border Height="8" VerticalAlignment="Top"    HorizontalAlignment="Stretch"
                                        Background="Transparent"
                                        WindowDecorationProperties.ElementRole="ResizeN"/>
                                <Border Height="8" VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                                        Background="Transparent"
                                        WindowDecorationProperties.ElementRole="ResizeS"/>
                    
                    <!-- 四角（斜向拉伸） -->
                    <Border Width="12" Height="8" HorizontalAlignment="Left"  VerticalAlignment="Top"
                            Background="Transparent"
                            WindowDecorationProperties.ElementRole="ResizeNW"/>
                    <Border Width="12" Height="8" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Background="Transparent"
                            WindowDecorationProperties.ElementRole="ResizeNE"/>
                    <Border Width="12" Height="8" HorizontalAlignment="Left"  VerticalAlignment="Bottom"
                            Background="Transparent"
                            WindowDecorationProperties.ElementRole="ResizeSW"/>
                    <Border Width="12" Height="8" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Background="Transparent"
                            WindowDecorationProperties.ElementRole="ResizeSE"/>
                </Panel>
                            </Grid>
                            
                            <!-- 顶部玻璃高光：模拟玻璃边缘反光 -->
                            <Border x:Name="GlassHighlightBorder"
                                    CornerRadius="12"
                                    BorderThickness="1,1,0,0"
                                    BorderBrush="{DynamicResource WindowGlassHighlightBrush}"
                                    IsHitTestVisible="False" />
                        </Grid>
                    </Border>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>