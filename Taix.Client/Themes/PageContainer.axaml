<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="using:Taix.Client.Controls">

    <ControlTheme x:Key="{x:Type controls:PageContainer}" TargetType="controls:PageContainer">
        <Setter Property="Template">
            <ControlTemplate>
                <ScrollViewer x:Name="ScrollViewer"
                              VerticalScrollBarVisibility="Auto">
                    <ContentPresenter x:Name="Frame" />
                </ScrollViewer>
            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>
