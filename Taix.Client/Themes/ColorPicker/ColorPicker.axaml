<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:base="using:Taix.Client.Controls.Base">

    <Design.PreviewWith>
        <StackPanel Width="400" Spacing="10" Margin="20">
            <base:ColorPicker />
        </StackPanel>
    </Design.PreviewWith>

    <ControlTheme x:Key="{x:Type base:ColorPicker}" TargetType="base:ColorPicker">
        <Setter Property="Background" Value="{DynamicResource InputBoxBgBrush}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{DynamicResource ButtonBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <StackPanel Spacing="16">
                        <!-- 色谱 + 色相滑块 + Alpha 滑块 -->
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <Border x:Name="SpectrumBorder"
                                    Grid.Column="0"
                                    Height="200"
                                    CornerRadius="6"
                                    Cursor="Cross">
                                <Canvas>
                                    <Border x:Name="SpectrumThumb"
                                            Width="16" Height="16"
                                            CornerRadius="8"
                                            BorderBrush="White"
                                            BorderThickness="2"
                                            Background="Transparent">
                                        <Border.BoxShadow>0 0 0 1 rgba(0,0,0,0.3)</Border.BoxShadow>
                                    </Border>
                                </Canvas>
                            </Border>

                            <Border x:Name="HueSliderTrack"
                                    Grid.Column="1"
                                    Width="24" Height="200"
                                    Margin="12,0,0,0"
                                    CornerRadius="6"
                                    Cursor="Hand">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                        <GradientStop Color="#FF0000" Offset="0.00" />
                                        <GradientStop Color="#FFFF00" Offset="0.17" />
                                        <GradientStop Color="#00FF00" Offset="0.33" />
                                        <GradientStop Color="#00FFFF" Offset="0.50" />
                                        <GradientStop Color="#0000FF" Offset="0.67" />
                                        <GradientStop Color="#FF00FF" Offset="0.83" />
                                        <GradientStop Color="#FF0000" Offset="1.00" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Canvas>
                                    <Border x:Name="HueSliderThumb"
                                            Width="24" Height="8"
                                            CornerRadius="2"
                                            Background="Transparent"
                                            BorderBrush="White"
                                            BorderThickness="2" />
                                </Canvas>
                            </Border>

                            <Border x:Name="AlphaSliderTrack"
                                    Grid.Column="2"
                                    Width="24" Height="200"
                                    Margin="8,0,0,0"
                                    CornerRadius="6"
                                    Cursor="Hand"
                                    IsVisible="{TemplateBinding IsAlphaVisible}">
                                <Canvas>
                                    <Border x:Name="AlphaSliderThumb"
                                            Width="24" Height="8"
                                            CornerRadius="2"
                                            Background="Transparent"
                                            BorderBrush="White"
                                            BorderThickness="2" />
                                </Canvas>
                            </Border>
                        </Grid>

                        <!-- Hex 输入 -->
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Grid.Column="0"
                                       Text="Hex"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource SubTextBrush}"
                                       FontSize="13"
                                       Margin="0,0,12,0" />
                            <TextBox x:Name="HexTextBox"
                                     Grid.Column="1"
                                     Height="32"
                                     Background="{DynamicResource InputBoxBgBrush}"
                                     BorderBrush="{DynamicResource ButtonBorderBrush}"
                                     BorderThickness="1"
                                     CornerRadius="6"
                                     Padding="10,0"
                                     FontSize="13"
                                     Foreground="{DynamicResource DefaultTextBrush}"
                                     VerticalContentAlignment="Center" />
                        </Grid>

                        <!-- 颜色预览 + RGB 值 -->
                        <Grid ColumnDefinitions="*,Auto">
                            <Border x:Name="PreviewBorder"
                                    Grid.Column="0"
                                    Height="40"
                                    CornerRadius="6"
                                    HorizontalAlignment="Stretch" />
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center"
                                        Margin="12,0,0,0">
                                <TextBlock Foreground="{DynamicResource SubTextBrush}"
                                           FontSize="12" Width="40"
                                           VerticalAlignment="Center">
                                    <Run Text="R:" /><Run Text="{Binding Color.R, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}" />
                                </TextBlock>
                                <TextBlock Foreground="{DynamicResource SubTextBrush}"
                                           FontSize="12" Width="40"
                                           VerticalAlignment="Center">
                                    <Run Text="G:" /><Run Text="{Binding Color.G, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}" />
                                </TextBlock>
                                <TextBlock Foreground="{DynamicResource SubTextBrush}"
                                           FontSize="12" Width="40"
                                           VerticalAlignment="Center">
                                    <Run Text="B:" /><Run Text="{Binding Color.B, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>
