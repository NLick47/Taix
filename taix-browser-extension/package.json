{
  "name": "taix-browser-extension",
  "version": "2.0.1",
  "description": "Taix 网页浏览时长统计插件 - 多浏览器支持",
  "scripts": {
    "build": "npm run build:chrome && npm run build:firefox && npm run build:safari",
    "build:chrome": "node scripts/build.js chrome",
    "build:firefox": "node scripts/build.js firefox",
    "build:safari": "node scripts/build.js safari",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/chrome": "^0.0.260",
    "esbuild": "^0.20.0"
  },
  "private": true
}
