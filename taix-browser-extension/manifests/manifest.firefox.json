{
  "manifest_version": 3,
  "name": "Taix Web Sentry",
  "version": "2.0.0",
  "description": "Taix 网页浏览时长统计插件",
  "permissions": [
    "tabs",
    "activeTab",
    "webNavigation",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/socket-inactive.svg",
      "48": "icons/socket-inactive.svg",
      "128": "icons/socket-inactive.svg"
    }
  },
  "icons": {
    "16": "icons/icon48.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}